<%# ESSENTIAL: Clinic engine pagination — styles in clinic_management/main.css (.clinic-pagination__*). %>
<%= paginator.render do %>
  <nav class="clinic-pagination" aria-label="Paginação">
    <ul class="clinic-pagination__list">
      <%= prev_page_tag %>
      <% each_page do |page| %>
        <% if page.left_outer? || page.right_outer? || page.inside_window? %>
          <%= page_tag page %>
        <% elsif !page.was_truncated? %>
          <%= gap_tag %>
        <% end %>
      <% end %>
      <%= next_page_tag %>
    </ul>
  </nav>
<% end %>
