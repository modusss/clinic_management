<!-- Turbo stream para receber atualizações quando uma interação é criada -->
<%= turbo_stream_from "lead_#{lead.id}_phone_tracking" %>

<div id="phone-container-<%= lead.id %>" 
     data-controller="message-tracking"
     data-message-tracking-lead-id-value="<%= lead.id %>"
     data-message-tracking-appointment-id-value="<%= appointment&.id %>"
     data-message-tracking-no-whatsapp-value="<%= lead.no_whatsapp || false %>"
     data-message-tracking-persist-hint-value="<%= local_assigns[:persist_hint] || false %>"
     data-message-tracking-row-id-value="lead-row-<%= lead.id %>"
     data-message-tracking-whatsapp-url-value="<%= whatsapp_link(lead.phone, "") %>"
     data-message-tracking-can-verify-whatsapp-value="<%= can_use_evolution_api? %>">
  <div class="flex items-center">
    <% if lead.phone.present? %>
      <div class="flex items-center gap-2">
        <%# Link do WhatsApp - verifica antes de abrir se Evolution API está disponível %>
        <% if can_use_evolution_api? %>
          <a href="#"
             data-action="click->message-tracking#verifyAndOpenWhatsapp"
             data-message-tracking-target="whatsappLink"
             class="whatsapp-link cursor-pointer <%= 'opacity-50' unless lead.has_whatsapp? %>">
            <%= add_phone_mask(lead.phone) %>
          </a>
        <% else %>
          <%# Fallback: link direto se não tiver Evolution API %>
          <%= link_to add_phone_mask(lead.phone), 
                      whatsapp_link(lead.phone, ""), 
                      target: '_blank',
                      data: { action: "click->message-tracking#recordMessageSent" },
                      class: "whatsapp-link #{'opacity-50' unless lead.has_whatsapp?}" %>
        <% end %>
        
        <%# Link tel: para ligar - data-turbo=false evita overlay de loading no clique %>
        <a style="display: inline-flex; align-items: center; color: #4B5563; text-decoration: none;" 
           href="tel:<%= current_user&.phone_prefix.present? ? current_user.phone_prefix : '' %><%= lead.phone %>" 
           title="Ligar para <%= current_user&.phone_prefix.present? ? current_user.phone_prefix : '' %><%= lead.phone %>"
           data-turbo="false"
           data-action="click->message-tracking#recordMessageSent">
          <i class="fas fa-phone" style="margin-right: 4px;"></i>
          <span style="font-size: 15px;">Ligar</span>
          <% if current_user&.phone_prefix.present? %>
            <span style="font-size: 10px; color: #9CA3AF; margin-left: 4px;" title="Prefixo configurado: <%= current_user.phone_prefix %>">(<%= current_user.phone_prefix %>)</span>
          <% end %>
        </a>
        
        <!-- WhatsApp Status Toggle -->
        <div class="flex items-center ml-2">
          <span class="text-xs text-gray-600 mr-1">WhatsApp:</span>
          <button type="button"
                  data-action="click->message-tracking#toggleWhatsappStatus"
                  class="relative inline-flex h-6 w-11 items-center rounded-full transition-colors focus:outline-none focus:ring-2 focus:ring-green-500 focus:ring-offset-2 <%= lead.has_whatsapp? ? 'bg-green-600' : 'bg-gray-200' %>"
                  title="<%= lead.has_whatsapp? ? 'Clique para marcar como sem WhatsApp' : 'Clique para marcar como tem WhatsApp' %>">
            <span class="inline-block h-4 w-4 transform rounded-full bg-white transition duration-200 ease-in-out <%= lead.has_whatsapp? ? 'translate-x-6' : 'translate-x-1' %>">
              <i class="fab fa-whatsapp text-xs <%= lead.has_whatsapp? ? 'text-green-600' : 'text-gray-400' %>" style="font-size: 13px; margin-left: 1px; margin-top: 1px; position: absolute; right: 2px; bottom: 0px"></i>
            </span>
          </button>
        </div>
      </div>
    <% end %>
  </div>
  
  <!-- Hint de verificação de WhatsApp (aparece durante a verificação) -->
  <div class="hidden mt-2" data-message-tracking-target="verificationHint">
    <div class="flex items-center gap-2 text-xs bg-blue-50 text-blue-700 px-3 py-2 rounded-lg border border-blue-200">
      <span data-message-tracking-target="verificationText">Verificando se o número possui WhatsApp...</span>
    </div>
  </div>
  
  <!-- Estatísticas das interações com dropdown -->
  <%# ESSENTIAL: Use the controller-preloaded collection on the absent page so
      interaction counters/history do not execute several queries per lead. %>
  <% interactions = if lead.association(:lead_interactions).loaded?
                      lead.lead_interactions.to_a
                    else
                      lead.lead_interactions.includes(:user).to_a
                    end %>
  <% recent_interactions = interactions.sort_by(&:occurred_at).reverse %>
  <% latest_interaction = recent_interactions.first %>
  <% if interactions.any? %>
    <div class="text-xs text-gray-500 mt-1 relative">
      <div class="flex items-center gap-2">
        <span class="bg-green-100 text-green-700 px-2 py-1 rounded text-xs" title="WhatsApp">
          <i class="fab fa-whatsapp text-xs"></i> <%= interactions.count(&:whatsapp_click?) %>x
        </span>
        <span class="bg-red-100 text-red-700 px-2 py-1 rounded text-xs" title="Tentativas de ligação">
          <i class="fas fa-phone text-xs"></i> <%= interactions.count(&:phone_call?) %>x
        </span>
        <span class="bg-emerald-100 text-emerald-800 px-2 py-1 rounded text-xs" title="Atendeu">
          <i class="fas fa-phone-volume text-xs"></i> <%= interactions.count(&:phone_call_answered?) %>x
        </span>
        
        <!-- Botão discreto para abrir histórico -->
        <button type="button" 
                class="text-gray-400 hover:text-gray-600 ml-1"
                data-action="click->message-tracking#toggleHistory"
                title="Ver histórico de contatos">
          <i class="fas fa-history text-xs"></i>
        </button>
      </div>
      
      <% if latest_interaction %>
        <div class="text-xs mt-1">
          Última: <%= time_ago_in_words(latest_interaction.occurred_at) %> atrás
          por <%= latest_interaction.user&.name %>
        </div>
        
        <!-- Destacar quando o usuário atual enviou a última mensagem -->
        <% if latest_interaction.user == current_user %>
          <div class="text-xs mt-1 bg-blue-50 text-blue-700 px-2 py-1 rounded inline-block">
            <i class="fas fa-user-check text-xs mr-1"></i>
            Você enviou há <%= time_ago_in_words(latest_interaction.occurred_at) %>
          </div>
        <% end %>
      <% end %>
      
      <!-- Dropdown do histórico -->
      <div class="absolute top-full left-0 mt-1 bg-white border border-gray-200 rounded-lg shadow-lg z-50 min-w-80 hidden"
           data-message-tracking-target="historyDropdown">
        <div class="p-3">
          <div class="flex justify-between items-center mb-2">
            <h4 class="font-medium text-gray-700 text-sm">Histórico de Contatos</h4>
            <button type="button" 
                    class="text-gray-400 hover:text-gray-600"
                    data-action="click->message-tracking#toggleHistory">
              <i class="fas fa-times text-xs"></i>
            </button>
          </div>
          
          <div class="max-h-64 overflow-y-auto">
            <% recent_interactions.first(20).each do |interaction| %>
              <div class="flex items-center justify-between py-2 border-b border-gray-100 last:border-b-0">
                <div class="flex items-center gap-2">
                  <% if interaction.whatsapp_click? %>
                    <span class="text-green-600" title="WhatsApp"><i class="fab fa-whatsapp text-xs"></i></span>
                  <% elsif interaction.phone_call_answered? %>
                    <span class="text-emerald-700" title="Atendeu"><i class="fas fa-phone-volume text-xs"></i></span>
                  <% else %>
                    <span class="text-red-600" title="Tentativa"><i class="fas fa-phone text-xs"></i></span>
                  <% end %>
                  
                  <div class="text-xs">
                    <div class="font-medium text-gray-700">
                      <%= interaction&.user&.name %>
                    </div>
                    <div class="text-gray-500">
                      <%= l(interaction.occurred_at, format: "%d/%m/%Y às %H:%M") %>
                    </div>
                  </div>
                </div>
                
                <div class="text-xs text-gray-400">
                  <%= time_ago_in_words(interaction.occurred_at) %> atrás
                </div>
              </div>
            <% end %>
            
            <% if interactions.size > 20 %>
              <div class="text-center py-2 text-xs text-gray-500">
                ... e mais <%= interactions.size - 20 %> interações
              </div>
            <% end %>
          </div>
        </div>
      </div>
    </div>
  <% elsif appointment&.last_message_sent_at.present? %>
    <!-- Fallback para dados antigos -->
    <div class="text-xs text-gray-500 mt-1">
      Última mensagem: <%= time_ago_in_words(appointment.last_message_sent_at) %> atrás 
      por <%= appointment.last_message_sent_by %>
    </div>
  <% end %>
</div>
