<%# ESSENTIAL: Downloads tab — leads CSV only in clinic-only mode. %>
<div class="max-w-2xl space-y-4">
  <h2 class="text-lg font-semibold text-gray-900">Downloads</h2>
  <p class="text-sm text-gray-600">Exporte dados da clínica em CSV.</p>

  <%= link_to download_leads_csv_organization_path(format: :csv),
        class: "inline-flex items-center gap-2 rounded-lg bg-emerald-700 hover:bg-emerald-800 text-white font-semibold px-4 py-2.5 transition-colors" do %>
    <i class="fas fa-download" aria-hidden="true"></i>
    Baixar dados dos leads em CSV
  <% end %>
</div>
