<% content_for :footer, @company_name.presence || "Clínica" %>

<div class="max-w-2xl mx-auto">
  <nav class="text-sm text-emerald-800 mb-4" aria-label="Breadcrumb">
    <%= link_to "Organização", edit_organization_path(tab: "memberships"), class: "hover:underline" %>
    <span class="mx-1">/</span>
    <span class="text-gray-600">Editar cooperador</span>
  </nav>

  <div class="bg-white rounded-xl shadow-md border border-gray-200 overflow-hidden">
    <div class="bg-gradient-to-r from-emerald-800 to-emerald-700 px-6 py-4">
      <h1 class="text-xl font-semibold text-white"><%= @user.name %></h1>
      <p class="text-emerald-100 text-sm mt-1"><%= @user.email %></p>
    </div>

    <div class="p-6">
      <%= form_with model: @user, url: organization_cooperator_path(@user), method: :patch, local: true, html: { class: "space-y-4" } do |form| %>
        <div>
          <%= form.label :name, "Nome", class: "block text-sm font-medium text-gray-700 mb-1" %>
          <%= form.text_field :name, required: true, class: "w-full rounded-lg border border-gray-300 px-3 py-2.5" %>
        </div>
        <div>
          <%= form.label :role, "Cargo", class: "block text-sm font-medium text-gray-700 mb-1" %>
          <%= form.select :role,
              options_for_select(membership_role_options(@membership), @membership.role),
              {},
              class: "w-full rounded-lg border border-gray-300 px-3 py-2.5 bg-white" %>
        </div>
        <div class="flex flex-wrap justify-end gap-3 pt-2">
          <%= link_to "Cancelar", edit_organization_path(tab: "memberships"), class: "text-sm font-medium text-gray-600 hover:text-emerald-700 px-3 py-2" %>
          <%= form.submit "Salvar", class: "cursor-pointer inline-flex items-center rounded-lg bg-emerald-700 hover:bg-emerald-800 text-white font-semibold px-5 py-2.5" %>
        </div>
      <% end %>
    </div>
  </div>
</div>
