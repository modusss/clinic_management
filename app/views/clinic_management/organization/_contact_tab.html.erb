<%# ESSENTIAL: Clinic-only Organization — contact tab uses account_clinic_contact_info + clinic_logo (not ótica). %>
<% clinic_contact = account.account_clinic_contact_info || account.build_account_clinic_contact_info %>
<div class="max-w-3xl">
  <h2 class="text-lg font-semibold text-gray-900 mb-1">Informações de contato e endereço</h2>
  <p class="text-sm text-gray-600 mb-6">Essas informações aparecem nos documentos gerados pela clínica (receitas, PDFs de exame, etc.).</p>

  <%= form_with model: account, url: organization_path, method: :patch, local: true, html: { multipart: true, class: "space-y-5" } do |form| %>
    <%= form.fields_for :account_clinic_contact_info, clinic_contact do |contact_form| %>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        <div class="sm:col-span-2">
          <%= contact_form.label :company_name, "Nome da empresa", class: "block text-sm font-medium text-gray-700 mb-1" %>
          <%= contact_form.text_field :company_name, class: "w-full rounded-lg border border-gray-300 px-3 py-2.5" %>
        </div>
        <div>
          <%= contact_form.label :cnpj, "CNPJ", class: "block text-sm font-medium text-gray-700 mb-1" %>
          <%= contact_form.text_field :cnpj, maxlength: 18, placeholder: "00.000.000/0000-00", class: "w-full rounded-lg border border-gray-300 px-3 py-2.5" %>
        </div>
        <div>
          <%= contact_form.label :phone1, "Telefone 1", class: "block text-sm font-medium text-gray-700 mb-1" %>
          <%= contact_form.text_field :phone1, class: "w-full rounded-lg border border-gray-300 px-3 py-2.5" %>
        </div>
        <div>
          <%= contact_form.label :phone2, "Telefone 2", class: "block text-sm font-medium text-gray-700 mb-1" %>
          <%= contact_form.text_field :phone2, class: "w-full rounded-lg border border-gray-300 px-3 py-2.5" %>
        </div>
        <div class="sm:col-span-2">
          <%= contact_form.label :street, "Endereço", class: "block text-sm font-medium text-gray-700 mb-1" %>
          <%= contact_form.text_field :street, class: "w-full rounded-lg border border-gray-300 px-3 py-2.5" %>
        </div>
        <div>
          <%= contact_form.label :neighborhood, "Bairro", class: "block text-sm font-medium text-gray-700 mb-1" %>
          <%= contact_form.text_field :neighborhood, class: "w-full rounded-lg border border-gray-300 px-3 py-2.5" %>
        </div>
        <div>
          <%= contact_form.label :zip_code, "CEP", class: "block text-sm font-medium text-gray-700 mb-1" %>
          <%= contact_form.text_field :zip_code, class: "w-full rounded-lg border border-gray-300 px-3 py-2.5" %>
        </div>
        <div>
          <%= contact_form.label :city, "Cidade", class: "block text-sm font-medium text-gray-700 mb-1" %>
          <%= contact_form.text_field :city, class: "w-full rounded-lg border border-gray-300 px-3 py-2.5" %>
        </div>
        <div>
          <%= contact_form.label :state, "Estado (UF)", class: "block text-sm font-medium text-gray-700 mb-1" %>
          <%= contact_form.text_field :state, maxlength: 2, class: "w-full rounded-lg border border-gray-300 px-3 py-2.5 uppercase" %>
        </div>
      </div>
    <% end %>

    <div class="pt-4 border-t border-gray-100 space-y-4">
      <h3 class="text-sm font-semibold uppercase tracking-wide text-gray-500">Logo da clínica</h3>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 items-start">
        <div>
          <%= form.label :clinic_logo, "Enviar logo", class: "block text-sm font-medium text-gray-700 mb-1" %>
          <%= form.file_field :clinic_logo, accept: "image/*", class: "block w-full text-sm text-gray-600" %>
          <p class="text-xs text-gray-500 mt-1">JPG, PNG, GIF ou SVG — recomendado 200×200px</p>
        </div>
        <% if account.clinic_logo.attached? %>
          <div class="rounded-lg border border-gray-200 p-4 text-center bg-gray-50">
            <%= image_tag main_app.url_for(account.clinic_logo), class: "mx-auto max-h-40 object-contain mb-3", alt: "Logo da clínica" %>
            <%= button_to "Remover logo",
                  clinic_logo_organization_path,
                  method: :delete,
                  form: { data: { turbo_confirm: "Tem certeza que deseja remover a logo da clínica?" } },
                  class: "inline-flex items-center rounded-lg bg-red-600 hover:bg-red-700 text-white text-sm font-semibold px-4 py-2" %>
          </div>
        <% end %>
      </div>
    </div>

    <div class="flex justify-end pt-4">
      <%= form.submit "Salvar contato", class: "cursor-pointer inline-flex items-center rounded-lg bg-emerald-700 hover:bg-emerald-800 text-white font-semibold px-5 py-2.5" %>
    </div>
  <% end %>
</div>
