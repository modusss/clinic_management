<%# ESSENTIAL: Profile link in clinic sidebar when host account is "Apenas Clínica" (retail_module_enabled false). %>
<% if current_account&.clinic_only? %>
  <div class="pt-3 mt-3 border-t border-emerald-800">
    <% if is_manager_above? %>
      <%= link_to "Organização",
          clinic_management.edit_organization_path,
          class: "text-emerald-50 hover:bg-emerald-800 hover:text-white px-3 py-2 rounded-md flex items-center gap-2 #{'bg-emerald-950 text-white' if controller_name == 'organization'}" %>
    <% end %>
    <% if is_manager_above? && current_account&.referral_indicators_enabled? %>
      <%= link_to "Indicadores",
          clinic_management.referral_indicators_path,
          class: "text-emerald-50 hover:bg-emerald-800 hover:text-white px-3 py-2 rounded-md flex items-center gap-2 #{'bg-emerald-950 text-white' if controller_name == 'referral_indicators'}" %>
    <% end %>
    <%= link_to "Perfil",
        clinic_management.edit_profile_path,
        class: "text-emerald-50 hover:bg-emerald-800 hover:text-white px-3 py-2 rounded-md flex items-center gap-2 #{'bg-emerald-950 text-white' if controller_name == 'profiles'}" %>
  </div>
<% end %>
