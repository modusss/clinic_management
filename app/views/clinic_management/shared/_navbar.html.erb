<script>
  <%# Go-to-service modal: now handled by Stimulus (go_to_service_modal_controller.js) — Turbo-safe. %>
  /**
   * Copies the share link to clipboard and shows visual feedback.
   * 
   * @param {HTMLElement} button - The button element clicked
   * @param {string} url - The URL to copy
   */
  function copyShareLink(button, url) {
    const originalContent = button.innerHTML;
    
    navigator.clipboard.writeText(url).then(function() {
      // Success feedback
      button.innerHTML = '<i class="fas fa-check"></i><span>Link copiado!</span>';
      button.classList.add('copy-success');
      
      setTimeout(function() {
        button.innerHTML = originalContent;
        button.classList.remove('copy-success');
      }, 2000);
    }).catch(function(err) {
      // Fallback for older browsers
      const textArea = document.createElement('textarea');
      textArea.value = url;
      textArea.style.position = 'fixed';
      textArea.style.left = '-9999px';
      document.body.appendChild(textArea);
      textArea.select();
      
      try {
        document.execCommand('copy');
        button.innerHTML = '<i class="fas fa-check"></i><span>Link copiado!</span>';
        button.classList.add('copy-success');
      } catch (e) {
        button.innerHTML = '<i class="fas fa-times"></i><span>Erro ao copiar</span>';
        button.classList.add('copy-error');
      }
      
      document.body.removeChild(textArea);
      
      setTimeout(function() {
        button.innerHTML = originalContent;
        button.classList.remove('copy-success', 'copy-error');
      }, 2000);
    });
  }
</script>