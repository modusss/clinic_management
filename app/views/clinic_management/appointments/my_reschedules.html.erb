<%= breadcrumb({title: "Meus Agendamentos", path: nil}) %>

<%# Toggle for table/cards view. Stores preference in a cookie. %>
<%= render partial: "clinic_management/shared/toggle_cards_table", locals: { 
      path: ->(args = {}) { url_for(params.permit!.merge(args)) }, 
      cookie_name: "preferred_reschedules_view", 
      view_type: @view_type || 'table'
    } %>

<div class="container py-8">
  <div class="mb-8">
    <h1 class="text-3xl font-bold text-gray-900 mb-2 px-4">Meus Agendamentos</h1>
    <p class="text-gray-600 px-4">Lista de agendamentos realizados por você.</p>
  </div>

  <!-- Filtros de Conversão (Comprou/Não Comprou) -->
  <div class="px-4 mb-4">
    <div class="flex items-center gap-3">
      <span class="text-sm font-medium text-gray-700">Conversão:</span>
      
      <%= link_to my_reschedules_appointments_path,
                  class: "inline-flex items-center px-3 py-1.5 rounded-lg text-sm font-medium transition-colors #{@conversion_filter.nil? ? 'bg-gray-700 text-white' : 'bg-gray-100 text-gray-700 hover:bg-gray-200'}" do %>
        Todos
      <% end %>
      
      <%= link_to my_reschedules_appointments_path(conversion_filter: 'purchased'),
                  class: "inline-flex items-center px-3 py-1.5 rounded-lg text-sm font-medium transition-colors #{@conversion_filter == 'purchased' ? 'bg-green-600 text-white' : 'bg-green-50 text-green-700 hover:bg-green-100'}" do %>
        <svg class="w-4 h-4 mr-1.5" fill="currentColor" viewBox="0 0 20 20">
          <path d="M3 1a1 1 0 000 2h1.22l.305 1.222a.997.997 0 00.01.042l1.358 5.43-.893.892C3.74 11.846 4.632 14 6.414 14H15a1 1 0 000-2H6.414l1-1H14a1 1 0 00.894-.553l3-6A1 1 0 0017 3H6.28l-.31-1.243A1 1 0 005 1H3zM16 16.5a1.5 1.5 0 11-3 0 1.5 1.5 0 013 0zM6.5 18a1.5 1.5 0 100-3 1.5 1.5 0 000 3z"></path>
        </svg>
        Compraram
        <span class="ml-1.5 px-2 py-0.5 rounded-full text-xs bg-green-200 text-green-800">
          <%= @purchased_count %>
        </span>
      <% end %>
      
      <%= link_to my_reschedules_appointments_path(conversion_filter: 'not_purchased'),
                  class: "inline-flex items-center px-3 py-1.5 rounded-lg text-sm font-medium transition-colors #{@conversion_filter == 'not_purchased' ? 'bg-red-600 text-white' : 'bg-red-50 text-red-700 hover:bg-red-100'}" do %>
        <svg class="w-4 h-4 mr-1.5" fill="currentColor" viewBox="0 0 20 20">
          <path fill-rule="evenodd" d="M13.477 14.89A6 6 0 015.11 6.524l8.367 8.368zm1.414-1.414L6.524 5.11a6 6 0 018.367 8.367zM18 10a8 8 0 11-16 0 8 8 0 0116 0z" clip-rule="evenodd"></path>
        </svg>
        Não Compraram
        <span class="ml-1.5 px-2 py-0.5 rounded-full text-xs bg-red-200 text-red-800">
          <%= @not_purchased_count %>
        </span>
      <% end %>
    </div>
  </div>

  <%# Render table or cards view based on @view_type %>
  <% if @rows.present? %>
    <% if (@view_type || 'table') == 'cards' %>
      <%= render partial: "reschedule_cards", locals: { rows: @rows } %>
    <% else %>
      <div data-controller="table" class="overflow-hidden border-gray-200 sm:rounded-lg">
          <%= data_table(@rows) %>
          <br>
      </div>
    <% end %>
  <% else %>
    <div class="bg-white shadow sm:rounded-lg">
      <div class="px-4 py-5 sm:p-6">
        <h2 class="text-xl font-medium text-gray-900">Nenhum agendamento encontrado.</h2>
        <p class="mt-2 text-sm text-gray-600">Você ainda não fez nenhum agendamento.</p>
      </div>
    </div>
  <% end %>
  
  <% if @appointments.present? %>
    <div class="mt-6">
      <%= paginate @appointments %>
    </div>
  <% end %>
  
  <br>
  <br>
  <br>
  <br>
</div>

<style>
/* Abas responsivas */
nav[aria-label="Tabs"] {
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
}

nav[aria-label="Tabs"]::-webkit-scrollbar {
    display: none;
}

@media screen and (max-width: 767px) {
    .patient-name.nowrap{
        white-space: normal;
    }
    
    .comments {
        white-space: normal;
        max-width: 200px;
        word-wrap: break-word;
    }
    
    /* Abas em mobile */
    nav[aria-label="Tabs"] {
        flex-wrap: nowrap;
    }
    
    nav[aria-label="Tabs"] a {
        flex-shrink: 0;
    }
}

.reschedule-comments {
    max-width: 300px;
}

.reschedule-comments textarea {
    min-height: 60px;
    font-size: 14px;
}

.reschedule-comments .mt-2 {
    font-size: 11px;
}

/* Estilo para links do WhatsApp */
.fa-whatsapp {
    color: #25D366;
}

/* Melhorar aparência dos links */
a.text-blue-500:hover {
    text-decoration: underline;
}
</style>
