<%= form_with model: new_appointment, 
              url: old_appointment.present? ? reschedule_appointment_path(old_appointment) : appointments_path, 
              method: :post, 
              local: true, 
              html: { 
                class: "items-start sm:items-center space-y-2 sm:space-y-0 sm:space-x-2 w-full",
                id: old_appointment.present? ? "reschedule-trigger-form-#{old_appointment.id}" : nil
              } do |f| %>
  
  <%# ESSENTIAL: Reminder only when multi-locations mode enabled. Always uses navbar selection — flexible. %>
  <% if current_account&.multi_service_locations_enabled? && ClinicManagement::ServiceLocation.any? %>
    <% current_location_label = current_service_location_id.blank? ? "Interno" : (current_service_location_id.to_s == "all" ? "Todos externos" : (ClinicManagement::ServiceLocation.find_by(id: current_service_location_id)&.name || "Interno")) %>
    <div class="flex items-center gap-1.5 mb-2 px-2 py-1.5 bg-amber-50 border border-amber-200 rounded text-amber-800 text-xs w-full basis-full" role="status" aria-live="polite">
      <i class="fas fa-map-marker-alt text-amber-600 flex-shrink-0" aria-hidden="true"></i>
      <span><strong>Local ativo:</strong> <%= current_location_label %> — a remarcação será para este local</span>
    </div>
  <% end %>

  <%# ESSENTIAL: Local selector only when navbar is "Todos externos" — user needs to pick which external.
      When navbar has specific location or Interno, the reminder above is enough; select would be redundant. %>
  <% show_location_select = current_account&.multi_service_locations_enabled? && ClinicManagement::ServiceLocation.any? && old_appointment.present? && current_service_location_id.to_s == "all" %>
  <% if show_location_select %>
    <% default_location_id = old_appointment.service&.service_location_id.to_s %>
    <div class="w-full sm:w-auto">
      <label for="reschedule-location-filter-<%= old_appointment.id %>" class="block text-gray-700 text-sm font-bold mb-1">Local:</label>
      <select id="reschedule-location-filter-<%= old_appointment.id %>" 
              class="w-full shadow appearance-none border rounded py-2 px-3 text-gray-700 leading-tight focus:outline-none focus:shadow-outline reschedule-location-filter"
              data-appointment-id="<%= old_appointment.id %>">
        <option value="" <%= 'selected' if default_location_id.blank? %>>Interno</option>
        <% ClinicManagement::ServiceLocation.order(:name).each do |loc| %>
          <option value="<%= loc.id %>" <%= 'selected' if default_location_id == loc.id.to_s %>><%= loc.name %></option>
        <% end %>
      </select>
    </div>
  <% end %>

  <div class="w-full sm:w-auto">
    <%= f.label :service_id, "Escolha o dia:", class: "block text-gray-700 text-sm font-bold mb-1" %>
    <select name="appointment[service_id]" 
            id="reschedule-service-select-<%= old_appointment ? old_appointment.id : 'new' %>"
            class="w-full shadow appearance-none border rounded py-2 px-3 text-gray-700 leading-tight focus:outline-none focus:shadow-outline reschedule-service-select"
            data-appointment-id="<%= old_appointment&.id %>">
      <option value="">Selecione...</option>
      <% available_services.each do |svc| %>
        <option value="<%= svc.id %>" 
                data-service-location-id="<%= svc.service_location_id.to_s %>"><%= display_service_name(svc) %></option>
      <% end %>
    </select>
  </div>

  <% if (controller_name == "leads") && (action_name == "show") %>
    <% if referral?(current_user) %>
      <%= f.hidden_field :referral_id, value: user_referral.id %>
    <% else %>
      <%= f.label :referral_id, "Indicação: ", class: "text-gray-700 text-sm font-bold" %>
      <%= f.collection_select :referral_id, Referral.all, :id, :name, {selected: old_appointment&.invitation&.referral&.id}, {class: "shadow appearance-none border rounded py-2 px-3 text-gray-700 leading-tight focus:outline-none focus:shadow-outline"} %>
    <% end %>
  <% elsif (controller_name == "leads") && (action_name == "absent") %> 
    <% if referral?(current_user) %>
      <%= f.hidden_field :referral_id, value: user_referral.id %>
    <% elsif old_appointment.created_at > 6.months.ago %>
      <%= f.hidden_field :referral_id, value: old_appointment.invitation.referral.id %>
    <% end %>
  <% end %>

  <% if old_appointment.blank? %>
    <%= f.hidden_field :lead_id, value: lead.id %>
  <% end %>
  <br>
  <% if referral?(current_user) %>
    <%= f.submit "Remarcação de " + (referral?(current_user) ? user_referral.name : old_appointment&.invitation&.referral&.name), class: "bg-blue-600 hover:bg-blue-800 text-white font-bold py-2 px-4 rounded" %>
  <% else %> 
    <% if (controller_name == "leads") && (action_name == "absent") && (old_appointment.created_at > 6.months.ago) %>
      <%= f.submit "Remarcação de " + (referral?(current_user) ? user_referral.name : old_appointment&.invitation&.referral&.name), class: "bg-blue-600 hover:bg-blue-800 text-white font-bold py-2 px-4 rounded" %>
    <% elsif controller_name == "leads"%>
      <%= f.submit old_appointment.present? ? "Remarcar" : "Marcar", class: "bg-blue-600 hover:bg-blue-800 text-white font-bold py-2 px-4 rounded" %>
    <% else %>
      <%= f.submit "Remarcação de " + (referral?(current_user) ? user_referral.name : old_appointment&.invitation&.referral&.name), class: "bg-blue-600 hover:bg-blue-800 text-white font-bold py-2 px-4 rounded" %>
    <% end %>
  <% end %>

<% end %>

<% if old_appointment.present? %>
<script>
  (function() {
    // ESSENTIAL: Filter service options by selected Local when multi_service_locations_enabled.
    // Each form has unique ids: reschedule-location-filter-{id}, reschedule-service-select-{id}.
    var locationFilter = document.getElementById('reschedule-location-filter-<%= old_appointment.id %>');
    var serviceSelect = document.getElementById('reschedule-service-select-<%= old_appointment.id %>');
    if (locationFilter && serviceSelect) {
      function filterServicesByLocation() {
        var selectedLocId = locationFilter.value || '';
        var options = serviceSelect.querySelectorAll('option[data-service-location-id]');
        options.forEach(function(opt) {
          var optLocId = opt.getAttribute('data-service-location-id') || '';
          opt.style.display = (selectedLocId === optLocId) ? '' : 'none';
          if (opt.style.display === 'none' && opt.selected) {
            opt.selected = false;
            serviceSelect.querySelector('option[value=""]') && (serviceSelect.querySelector('option[value=""]').selected = true);
          }
        });
      }
      locationFilter.addEventListener('change', filterServicesByLocation);
      filterServicesByLocation(); // Apply on load (default = original appointment's location)
    }
  })();
</script>
<% end %>
