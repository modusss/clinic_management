<% content_for :footer, @company_name.presence || "Clínica" %>

<div class="max-w-6xl mx-auto space-y-6">
  <div class="bg-white rounded-xl shadow-md border border-gray-200 overflow-hidden">
    <div class="bg-gradient-to-r from-emerald-800 to-emerald-700 px-6 py-4 flex flex-wrap items-center justify-between gap-3">
      <div>
        <h1 class="text-xl font-semibold text-white flex items-center gap-2">
          <i class="fas fa-handshake" aria-hidden="true"></i>
          Lista de indicadores
        </h1>
        <p class="text-emerald-100 text-sm mt-1">
          <span class="font-semibold text-white"><%= @active_quantity %></span>
          <%= @active_quantity == 1 ? "indicador ativo" : "indicadores ativos" %>
          · Total: <%= @quantity %>
        </p>
      </div>
    </div>

    <div class="p-4 sm:p-6">
      <% if @active_referrals.any? %>
        <div class="overflow-x-auto rounded-lg border border-gray-200">
          <table class="min-w-full divide-y divide-gray-200 text-sm">
            <thead class="bg-gray-50">
              <tr>
                <th class="px-4 py-3 text-left font-semibold text-gray-700">Nome</th>
                <th class="px-4 py-3 text-left font-semibold text-gray-700">Telefone</th>
                <th class="px-4 py-3 text-center font-semibold text-gray-700">Comissão</th>
                <th class="px-4 py-3 text-center font-semibold text-gray-700">Exibir Leads</th>
                <th class="px-4 py-3 text-right font-semibold text-gray-700">Ações</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-gray-100 bg-white">
              <% @active_referrals.each do |referral| %>
                <%= render "clinic_management/referral_indicators/row", referral: referral %>
              <% end %>
            </tbody>
          </table>
        </div>
      <% else %>
        <p class="text-gray-600 text-center py-8">Nenhum indicador ativo no momento.</p>
      <% end %>
    </div>
  </div>

  <% if @inactive_referrals.any? %>
    <details class="bg-white rounded-xl shadow-md border border-gray-200 overflow-hidden group">
      <summary class="cursor-pointer list-none px-6 py-4 bg-gray-50 flex items-center justify-between gap-3">
        <span class="font-medium text-gray-700">
          <i class="fas fa-chevron-down group-open:rotate-180 transition-transform mr-2 text-emerald-700"></i>
          <%= @inactive_quantity %> <%= @inactive_quantity == 1 ? "indicador inativo" : "indicadores inativos" %>
          <span class="text-gray-500 font-normal text-sm">(sem usuário associado)</span>
        </span>
      </summary>
      <div class="p-4 sm:p-6 border-t border-gray-100">
        <p class="text-amber-800 bg-amber-50 border border-amber-200 rounded-lg px-4 py-3 text-sm mb-4">
          Para reativar, vá em <strong>Organização → Adicionar cooperador</strong> e selecione "Reintegrar Indicador Existente".
        </p>
        <div class="overflow-x-auto rounded-lg border border-gray-200">
          <table class="min-w-full divide-y divide-gray-200 text-sm">
            <thead class="bg-gray-50">
              <tr>
                <th class="px-4 py-3 text-left font-semibold text-gray-700">Nome</th>
                <th class="px-4 py-3 text-left font-semibold text-gray-700">Telefone</th>
                <th class="px-4 py-3 text-center font-semibold text-gray-700">Comissão</th>
                <th class="px-4 py-3 text-center font-semibold text-gray-700">Exibir Leads</th>
                <th class="px-4 py-3 text-right font-semibold text-gray-700">Ações</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-gray-100 bg-white">
              <% @inactive_referrals.each do |referral| %>
                <%= render "clinic_management/referral_indicators/row", referral: referral %>
              <% end %>
            </tbody>
          </table>
        </div>
      </div>
    </details>
  <% end %>

  <% if is_manager_above? %>
    <div class="rounded-xl border border-sky-200 bg-sky-50 px-5 py-4 text-sm text-sky-900">
      <p class="font-semibold mb-1">Como adicionar um novo indicador?</p>
      <p class="mb-3">Acesse <strong>Organização → Adicionar Cooperador</strong> e selecione o cargo "Indicador".</p>
      <%= link_to "Ir para Organização", main_app.edit_account_path(current_account),
          class: "inline-flex items-center rounded-lg bg-sky-700 hover:bg-sky-800 text-white font-medium px-4 py-2 transition-colors" %>
    </div>
  <% end %>
</div>
