<% content_for :footer, @company_name.presence || "Clínica" %>

<div class="max-w-4xl mx-auto">
  <nav class="text-sm text-emerald-800 mb-4" aria-label="Breadcrumb">
    <%= link_to "Indicadores", referral_indicators_path, class: "hover:underline" %>
    <span class="mx-1">/</span>
    <%= link_to @referral.name, commissions_referral_indicator_path(@referral), class: "hover:underline" %>
    <span class="mx-1">/</span>
    <span class="text-gray-600">Histórico de pagamentos</span>
  </nav>

  <div class="bg-white rounded-xl shadow-md border border-gray-200 overflow-hidden">
    <div class="bg-gradient-to-r from-emerald-800 to-emerald-700 px-6 py-4">
      <h1 class="text-xl font-semibold text-white">Histórico — <%= @referral.name %></h1>
    </div>
    <div class="p-6 space-y-4">
      <ul class="grid grid-cols-1 sm:grid-cols-3 gap-3 text-sm">
        <li class="rounded-lg border border-gray-200 bg-gray-50 px-4 py-3">Recebidas: <strong><%= @paid_commissions %></strong></li>
        <li class="rounded-lg border border-gray-200 bg-gray-50 px-4 py-3">Pendentes: <strong><%= @pending_commissions %></strong></li>
        <li class="rounded-lg border border-gray-200 bg-gray-50 px-4 py-3">Aguardando: <strong><%= @waiting_commissions %></strong></li>
      </ul>

      <% if @payment_histories.any? %>
        <div class="overflow-x-auto rounded-lg border border-gray-200">
          <table class="min-w-full divide-y divide-gray-200 text-sm">
            <thead class="bg-gray-50">
              <tr>
                <th class="px-4 py-3 text-left font-semibold text-gray-700">#</th>
                <th class="px-4 py-3 text-left font-semibold text-gray-700">Data</th>
                <th class="px-4 py-3 text-left font-semibold text-gray-700">OS</th>
                <th class="px-4 py-3 text-left font-semibold text-gray-700">Cliente</th>
                <th class="px-4 py-3 text-right font-semibold text-gray-700">Qtd</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-gray-100">
              <% @payment_histories.each_with_index do |history, index| %>
                <tr>
                  <td class="px-4 py-3"><%= index + 1 %></td>
                  <td class="px-4 py-3"><%= history.payment_date.strftime("%d/%m/%Y") %></td>
                  <td class="px-4 py-3"><%= history.order_number %></td>
                  <td class="px-4 py-3"><%= history.customer_name %></td>
                  <td class="px-4 py-3 text-right"><%= history.quantity %></td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
        <div class="flex justify-center pt-2"><%= paginate(@payment_histories) %></div>
      <% else %>
        <p class="text-center text-gray-600 py-6">Nenhum histórico de pagamento encontrado.</p>
      <% end %>
    </div>
  </div>
</div>
