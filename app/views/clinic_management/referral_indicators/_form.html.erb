<%# ESSENTIAL: Tailwind referral form — same fields/Stimulus as host referrals/_form. %>
<%= form_with model: referral,
              url: referral_indicator_path(referral),
              method: :patch,
              local: true,
              html: { class: "space-y-6", data: { controller: "referral-form" } } do |form| %>

  <% if referral.errors.any? %>
    <div class="rounded-lg border border-red-200 bg-red-50 px-4 py-3 text-red-800 text-sm" role="alert">
      <p class="font-semibold mb-1">Corrija os erros abaixo:</p>
      <ul class="list-disc list-inside space-y-0.5">
        <% referral.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <section class="space-y-4">
    <h2 class="text-sm font-semibold uppercase tracking-wide text-gray-500">Dados do indicador</h2>
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
      <div>
        <%= form.label :name, "Nome completo", class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= form.text_field :name, required: true, class: "w-full rounded-lg border border-gray-300 px-3 py-2.5 focus:ring-2 focus:ring-emerald-500 focus:border-emerald-500" %>
      </div>
      <div>
        <%= form.label :phone, "Telefone", class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= form.text_field :phone, class: "w-full rounded-lg border border-gray-300 px-3 py-2.5 focus:ring-2 focus:ring-emerald-500 focus:border-emerald-500" %>
      </div>
    </div>
  </section>

  <section class="space-y-4 pt-4 border-t border-gray-100">
    <h2 class="text-sm font-semibold uppercase tracking-wide text-gray-500">Configuração de comissão</h2>
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
      <div>
        <%= form.label :commission_type, "Tipo de comissão", class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= form.select :commission_type,
            { "Fixo" => "fixed", "Porcentagem" => "percentage" },
            { include_blank: "Selecione o tipo..." },
            required: true,
            class: "w-full rounded-lg border border-gray-300 px-3 py-2.5 bg-white focus:ring-2 focus:ring-emerald-500 focus:border-emerald-500",
            data: {
              referral_form_target: "commissionTypeSelect",
              action: "change->referral-form#onCommissionTypeChange"
            } %>
      </div>
      <div data-referral-form-target="percentageSection" style="<%= referral.commission_type == 'percentage' ? '' : 'display: none;' %>">
        <%= form.label :percentage, "Percentual (%)", class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= form.number_field :percentage, step: :any, placeholder: "Ex: 10",
            class: "w-full rounded-lg border border-gray-300 px-3 py-2.5 focus:ring-2 focus:ring-emerald-500 focus:border-emerald-500",
            data: { referral_form_target: "percentageInput" } %>
      </div>
    </div>
  </section>

  <section class="space-y-4 pt-4 border-t border-gray-100">
    <h2 class="text-sm font-semibold uppercase tracking-wide text-gray-500">Permissões</h2>

    <div class="rounded-lg border border-gray-200 bg-gray-50 p-4">
      <%= form.label :is_exam_scheduler, class: "flex items-start gap-3 cursor-pointer" do %>
        <%= form.check_box :is_exam_scheduler,
            class: "mt-1 rounded border-gray-300 text-emerald-600 focus:ring-emerald-500",
            data: {
              referral_form_target: "examSchedulerCheckbox",
              action: "change->referral-form#updatePermissions"
            } %>
        <span>
          <span class="block font-medium text-gray-900">É um agendador de exame?</span>
          <span class="block text-sm text-gray-600">Habilita convites e marcações na página de comissões.</span>
        </span>
      <% end %>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
      <div class="rounded-lg border border-gray-200 bg-gray-50 p-4"
           data-referral-form-target="leadsSection"
           style="<%= referral.is_exam_scheduler ? '' : 'display: none;' %>">
        <%= form.label :can_access_leads, class: "flex items-start gap-3 cursor-pointer" do %>
          <%= form.check_box :can_access_leads, class: "mt-1 rounded border-gray-300 text-emerald-600 focus:ring-emerald-500" %>
          <span>
            <span class="block font-medium text-gray-900">Acesso à lista de leads</span>
            <span class="block text-sm text-gray-600">Permite visualizar e gerenciar leads.</span>
          </span>
        <% end %>
      </div>

      <div class="rounded-lg border border-gray-200 bg-gray-50 p-4"
           data-referral-form-target="whatsappSection"
           style="<%= referral.is_exam_scheduler ? '' : 'display: none;' %>">
        <%= form.label :can_connect_whatsapp, class: "flex items-start gap-3 cursor-pointer" do %>
          <%= form.check_box :can_connect_whatsapp, class: "mt-1 rounded border-gray-300 text-emerald-600 focus:ring-emerald-500" %>
          <span>
            <span class="block font-medium text-gray-900">Conectar WhatsApp</span>
            <span class="block text-sm text-gray-600">Permite conectar WhatsApp para mensagens.</span>
          </span>
        <% end %>
      </div>
    </div>
  </section>

  <div class="flex flex-wrap items-center justify-end gap-3 pt-4 border-t border-gray-100">
    <%= link_to "Cancelar", referral_indicators_path, class: "text-sm font-medium text-gray-600 hover:text-emerald-700 px-3 py-2" %>
    <%= form.submit "Atualizar indicador", class: "cursor-pointer inline-flex items-center justify-center rounded-lg bg-emerald-700 hover:bg-emerald-800 text-white font-semibold px-5 py-2.5 shadow-sm transition-colors" %>
  </div>
<% end %>
