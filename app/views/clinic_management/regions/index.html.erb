<% content_for :title, "Regiões" %>

<h1 class="text-3xl font-bold mb-4">Regiões</h1>

<p class="text-gray-600 mb-6 max-w-2xl">
  <i class="fas fa-info-circle text-emerald-500 mr-2" aria-hidden="true"></i>
  Use esta página para fazer um diagnóstico de quais regiões são mais promissoras para o atendimento interno da clínica, com base na captação de pacientes. A quantidade de convites por região ajuda a identificar onde concentrar esforços de divulgação.
</p>

<%= link_to "Nova Região", new_region_path, class: "inline-flex items-center rounded-md bg-blue-600 px-4 py-2 text-sm font-medium text-white hover:bg-blue-700 mb-4" %>

<!-- Opções de ordenação -->
<div class="my-4 p-4 bg-gray-100 rounded">
  <%= form_with url: regions_path, method: :get, local: true, class: "flex flex-wrap gap-4 items-center" do |f| %>
    
    <div>
      <%= f.label :sort_by, "Ordenar por:", class: "font-semibold mr-2" %>
      <%= f.select :sort_by, 
          options_for_select([
            ["Nome (A-Z)", "name"],
            ["Mais convites primeiro", "invitations_desc"],
            ["Menos convites primeiro", "invitations_asc"]
          ], params[:sort_by]), 
          { include_blank: false },
          { class: "border rounded p-2", onchange: "this.form.submit();" }
      %>
    </div>
    
  <% end %>
</div>

<%= data_table(@rows) %>
<br>

