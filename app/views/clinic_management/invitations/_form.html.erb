<%= form_with(model: invitation, class: "invitation-form w-full max-w-2xl mx-auto mt-6", id: "new_invitation") do |form| %>
  <% if invitation.errors.any? %>
    <div class="bg-red-200 border-red-600 border-l-4 p-4 mb-6">
      <h2 class="text-red-800 font-bold"><%= pluralize(invitation.errors.count, "erro") %> impediram que o convite fosse salvo:</h2>
      <ul class="list-disc pl-6">
        <% invitation.errors.each do |error| %>
          <li class="text-red-600"><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <!-- Adicionar o controller Stimulus aqui -->
  <div data-controller="phone-checker" 
       data-phone-checker-check-url-value="<%= check_existing_phone_invitations_path %>"
       data-phone-checker-csrf-token-value="<%= form_authenticity_token %>">

    <section class="invitation-form-section">
    <h2 class="invitation-form-section__title"><span>1</span> Dados da marcação</h2>
    <% local_referral_id = local_assigns[:local_referral_id].to_s %>
    <% is_referral_local = local_referral_id.present? && (local_assigns[:referral].to_s == local_referral_id) %>
    <div class="mb-4" <%= raw("data-controller=\"referral-date-toggle\" data-referral-date-toggle-local-referral-id-value=\"#{local_referral_id}\"") if !referral?(current_user) && local_referral_id.present? %>>
      <% if referral? current_user %>
        <%= form.hidden_field :referral_id, value: user_referral.id %>
        <div class="mb-4">
          <%= form.label "Dia da marcação", class: "block text-gray-700 font-bold" %>
          <%= form.collection_select :date, 
            [ ["Hoje, " + Date.current.strftime("%d/%m/%Y"), Date.current],
              ["Ontem, " + (Date.current - 1.day).strftime("%d/%m/%Y"), (Date.current - 1.day)],
              ["Há 2 dias, " + (Date.current - 2.days).strftime("%d/%m/%Y"), (Date.current - 2.days)],
              ["Há 3 dias, " + (Date.current - 3.days).strftime("%d/%m/%Y"), (Date.current - 3.days)]
            ], 
            :last, :first, {selected: date},
            class: "w-full px-3 py-2 border rounded shadow appearance-none text-gray-700 leading-tight focus:outline-none focus:shadow-outline"
          %>
        </div>
      <% else %>
        <%= form.label :referral_id, "Captador", class: "block text-gray-700 font-bold" %>
        <% if local_assigns.key?(:referral_grouped_options) && referral_grouped_options.present? %>
          <%= form.select :referral_id, grouped_options_for_select(referral_grouped_options, referral),
              {},
              {class: "w-full px-3 py-2 border rounded shadow appearance-none text-gray-700 leading-tight focus:outline-none focus:shadow-outline",
               data: { referral_date_toggle_target: "referralSelect", action: "change->referral-date-toggle#toggle" }} %>
        <% else %>
          <%= form.collection_select :referral_id, referrals, :id, :name, {selected: referral},
              {class: "w-full px-3 py-2 border rounded shadow appearance-none text-gray-700 leading-tight focus:outline-none focus:shadow-outline",
               data: { referral_date_toggle_target: "referralSelect", action: "change->referral-date-toggle#toggle" }} %>
        <% end %>
        <%# When Indicador is "Local", Dia da marcação is hidden (implied today). %>
        <%= form.hidden_field :date, value: Date.current, data: { referral_date_toggle_target: "dateHidden" }, disabled: !is_referral_local %>
        <div class="mb-4" data-referral-date-toggle-target="dateField" style="<%= 'display:none' if is_referral_local %>">
          <%= form.label "Dia da marcação", class: "block text-gray-700 font-bold" %>
          <%= form.collection_select :date, 
            [ ["Hoje, " + Date.current.strftime("%d/%m/%Y"), Date.current],
              ["Ontem, " + (Date.current - 1.day).strftime("%d/%m/%Y"), (Date.current - 1.day)],
              ["Há 2 dias, " + (Date.current - 2.days).strftime("%d/%m/%Y"), (Date.current - 2.days)],
              ["Há 3 dias, " + (Date.current - 3.days).strftime("%d/%m/%Y"), (Date.current - 3.days)]
            ], 
            :last, :first, {selected: date.presence || Date.current},
            {class: "w-full px-3 py-2 border rounded shadow appearance-none text-gray-700 leading-tight focus:outline-none focus:shadow-outline",
             data: { referral_date_toggle_target: "dateSelect" },
             disabled: is_referral_local}
          %>
        </div>
      <% end %>
    </div>

    <%# ESSENTIAL: Local (Service Location) select - filters "Dia destinado" options below. %>
    <%# Only show when there are external locations to choose (Interno + at least one). %>
    <%# If referral has no allowed externals, hide entirely - they use Interno by default. %>
    <% has_external_locations = local_assigns.key?(:service_locations_for_select) && service_locations_for_select.present? && service_locations_for_select.size > 1 %>
    <% if has_external_locations %>
      <div class="mb-4" data-controller="service-location-filter"
           data-service-location-filter-new-url-value="<%= clinic_management.new_invitation_path %>">
        <label for="invitation_service_location_filter" class="block text-gray-700 font-bold">Local do atendimento</label>
        <select id="invitation_service_location_filter"
                class="w-full px-3 py-2 border rounded shadow appearance-none text-gray-700 leading-tight focus:outline-none focus:shadow-outline"
                data-service-location-filter-target="select"
                data-action="change->service-location-filter#reloadWithLocation">
          <% (service_locations_for_select || [["Interno", ""]]).each do |label, value| %>
            <option value="<%= value %>" <%= 'selected' if (local_assigns[:selected_service_location_id] || "") == value.to_s %>><%= label %></option>
          <% end %>
        </select>
      </div>
    <% end %>

    <%# Região: only shown when Local is "Interno". When external, use hidden default "Local" region. %>
    <% is_external_location = local_assigns.key?(:selected_service_location_id) && local_assigns[:selected_service_location_id].present? %>
    <% if is_external_location %>
      <% default_region = local_assigns[:default_region_id_for_external] || regions.find { |r| r.name == "Local" }&.id || regions.first&.id %>
      <%= form.hidden_field :region_id, value: default_region %>
    <% else %>
      <div class="mb-4">
        <%= form.label "Região de captação do paciente", class: "block text-gray-700 font-bold" %>
        <%= form.collection_select :region_id, regions, :id, :name,
              { selected: region }, 
              class: "w-full px-3 py-2 border rounded shadow appearance-none text-gray-700 leading-tight focus:outline-none focus:shadow-outline" %>
      </div>
    <% end %>

    <%= form.fields_for :appointments do |appointment_fields| %>
      <%= render "appointment_schedule_fields",
                 appointment_fields: appointment_fields,
                 services: services_list,
                 selected_service: service %>
    <% end %>
    </section>
    <section class="invitation-form-section">
    <h2 class="invitation-form-section__title"><span>2</span> Dados do convidado</h2>
    <%= form.fields_for :lead do |lead_fields| %>
      <div class="mb-4">
        <label for="lead_phone" class="block text-gray-700 font-bold mb-2">Telefone</label>
        <%= lead_fields.telephone_field :phone, 
            value: "(77) ", 
            maxlength: 15, 
            id: "lead_phone", 
            class: "w-full px-3 py-2 border rounded shadow appearance-none text-gray-700 leading-tight focus:outline-none focus:shadow-outline", 
            placeholder: "(77) 98888-8888",
            data: { 
              controller: "phone-mask",
              phone_mask_target: "input",
              phone_checker_target: "phoneInput",
              action: "blur->phone-checker#checkPhone focus->phone-checker#onPhoneFocus"
            }
        %>
        
        <!-- Área para mostrar o lead existente -->
        <div data-phone-checker-target="existingLeadAlert" class="hidden mt-3 p-4 border-l-4 border-yellow-400 bg-yellow-50">
          <div class="flex">
            <div class="flex-shrink-0">
              <svg class="h-5 w-5 text-yellow-400" viewBox="0 0 20 20" fill="currentColor">
                <path fill-rule="evenodd" d="M8.257 3.099c.765-1.36 2.722-1.36 3.486 0l5.58 9.92c.75 1.334-.213 2.98-1.742 2.98H4.42c-1.53 0-2.493-1.646-1.743-2.98l5.58-9.92zM11 13a1 1 0 11-2 0 1 1 0 012 0zm-1-8a1 1 0 00-1 1v3a1 1 0 002 0V6a1 1 0 00-1-1z" clip-rule="evenodd" />
              </svg>
            </div>
            <div class="ml-3">
              <h3 class="text-sm font-medium text-yellow-800">
                Telefone já cadastrado!
              </h3>
              <div class="mt-2 text-sm text-yellow-700" data-phone-checker-target="existingLeadInfo">
                <!-- Informações do lead serão inseridas aqui -->
              </div>
              <div class="mt-4">
                <div class="flex flex-wrap gap-2">
                  <button type="button" 
                          data-action="click->phone-checker#associate"
                          class="bg-green-500 hover:bg-green-600 text-white px-3 py-1 text-sm rounded">
                    ✓ Usar cadastro existente
                  </button>
                  <button type="button" 
                          data-action="click->phone-checker#transfer"
                          class="bg-orange-500 hover:bg-orange-600 text-white px-3 py-1 text-sm rounded">
                    ↔ Transferir telefone
                  </button>
                  <button type="button" 
                          data-action="click->phone-checker#cancel"
                          class="bg-gray-500 hover:bg-gray-600 text-white px-3 py-1 text-sm rounded">
                    ✕ Cancelar
                  </button>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    <% end %>

    <!-- Campo hidden para ação escolhida -->
    <%= hidden_field_tag :phone_action, '', data: { phone_checker_target: "phoneActionInput" } %>

    <div class="mb-4">
      <%= form.label "Nome do paciente", class: "block text-gray-700 font-bold" %>
      <%= form.text_field :patient_name, class: "w-full px-3 py-2 border rounded shadow appearance-none text-gray-700 leading-tight focus:outline-none focus:shadow-outline" %>
    </div>
    <%= form.fields_for :lead do |lead_fields| %>
      <div class="mb-4">
        <label for="lead_name" class="block text-gray-700 font-bold mb-2">Nome do responsável</label>
        <%= lead_fields.text_field :name, 
            class: "w-full px-3 py-2 border rounded shadow appearance-none text-gray-700 leading-tight focus:outline-none focus:shadow-outline", 
            placeholder: "Deixe em branco se o paciente é o responsável",
            data: { phone_checker_target: "nameField" } %>
      </div>

      <div class="mb-4">
        <label for="lead_address" class="block text-gray-700 font-bold mb-2">Endereço</label>
        <%= lead_fields.text_field :address, 
            class: "w-full px-3 py-2 border rounded shadow appearance-none text-gray-700 leading-tight focus:outline-none focus:shadow-outline",
            data: { phone_checker_target: "addressField" } %>
      </div>

      

    <% end %>

    <div class="mb-4">
      <%= form.label "Observações", class: "block text-gray-700 font-bold" %>
      <%= form.text_area :notes, class: "w-full px-3 py-2 border rounded shadow appearance-none text-gray-700 leading-tight focus:outline-none focus:shadow-outline" %>
    </div>

    <div class="my-4">
      <div id="validation" class="mb-3 text-sm font-medium text-red-700" role="alert" aria-live="polite"></div>
      <%= form.submit "Adicionar novo paciente", 
          class: "w-full sm:w-auto bg-blue-500 hover:bg-blue-700 text-white font-bold py-3 px-5 rounded-lg focus:outline-none focus:shadow-outline",
          data: { phone_checker_target: "submitButton" } %>
    </div>
    </section>

  </div> <!-- Fim do controller -->
<% end %>
