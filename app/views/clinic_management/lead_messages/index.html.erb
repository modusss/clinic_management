<%# ============================================================================
   # Lead Messages Index
   #
   # Three viewing modes:
   # 1. Referral user     → sees only their own messages (no dropdown, no tabs)
   # 2. Manager/owner     → sees global messages by default + dropdown to switch
   #                        to any referral's messages. Tabs only for global view.
   # 3. Other staff       → sees global messages with tabs (unchanged)
   # ============================================================================ %>

<div class="my-8">
  <% if @current_referral %>
    <h5 class="text-2xl font-bold">Minhas Mensagens Customizadas</h5>
    <p class="text-sm text-gray-600">Estas são as mensagens customizadas criadas por você.</p>
  <% else %>
    <h5 class="text-2xl font-bold">Mensagens Customizadas</h5>
  <% end %>
</div>

<%# ============================================================================
   # Location filter: uses navbar selection (current_service_location_id).
   # No duplicate selector on page - user switches via navbar dropdown.
   # ============================================================================ %>

<%# ============================================================================
   # SECTION 1: Referral selector dropdown (managers only)
   # Shows only when there are referrals with messages.
   # Server-side filtering via query param — robust and simple.
   # ============================================================================ %>
<% if can_manage_lead_messages? && !@current_referral && @referrals_with_messages&.any? %>
  <div class="mb-6"
       data-controller="referral-messages"
       data-referral-messages-base-path-value="<%= lead_messages_path %>">
    <label for="referral-select" class="block text-sm font-medium text-gray-700 mb-2">
      Visualizar mensagens de captador:
    </label>
    <select id="referral-select"
            data-referral-messages-target="select"
            data-action="change->referral-messages#filterByReferral"
            class="shadow appearance-none border rounded py-2 px-3 text-gray-700 leading-tight focus:outline-none focus:shadow-outline w-full max-w-md">
      <option value="" <%= 'selected' if @viewing_referral.nil? %>>
        Mensagens Globais (da conta)
      </option>
      <% @referrals_with_messages.each do |referral| %>
        <option value="<%= referral.id %>" <%= 'selected' if @viewing_referral&.id == referral.id %>>
          <%= referral.name %>
        </option>
      <% end %>
    </select>

    <% if @viewing_referral %>
      <p class="text-sm text-blue-600 mt-2">
        Visualizando mensagens de: <strong><%= @viewing_referral.name %></strong>
      </p>
    <% end %>
  </div>
<% end %>

<%# ============================================================================
   # SECTION 2: Content display
   # ============================================================================ %>

<% if @current_referral %>
  <%# REFERRALS: Show all their messages, no tabs, no dropdown (unchanged) %>
  <%= render partial: 'messages_table', locals: { messages_to_show: @messages, show_type_column: false, show_meta_column: false } %>

<% elsif @viewing_referral.present? %>
  <%# MANAGER VIEWING A REFERRAL'S MESSAGES: No tabs needed (referrals only have "outro" type) %>
  <p class="text-sm text-gray-600 mb-4">
    Mensagens customizadas criadas por <strong><%= @viewing_referral.name %></strong>.
    Você pode editar e excluir estas mensagens.
  </p>
  <%= render partial: 'messages_table', locals: { messages_to_show: @messages, show_type_column: false, show_meta_column: false } %>

<% else %>
  <%# GLOBAL VIEW %>
  <% if @show_automation_channel_ui %>
    <%= render partial: "automation_channel_header",
               locals: {
                 clinic_automation_channel: @clinic_automation_channel,
                 meta_automation_available: @meta_automation_available
               } %>
  <% end %>

  <div data-controller="referral-messages lead-messages-automation"
       data-lead-messages-automation-active-tab-value="<%= @automation_tab || 'evolution' %>">
    <div class="mb-6">
      <div class="border-b border-gray-200">
        <nav class="-mb-px flex space-x-4 flex-wrap">
          <button data-referral-messages-target="tab"
                  data-tab="globais"
                  data-action="click->referral-messages#switchTab"
                  class="py-2 px-4 border-b-2 font-medium text-sm transition-all border-blue-500 text-blue-600 cursor-pointer">
            Mensagens Globais
          </button>
          <button data-referral-messages-target="tab"
                  data-tab="personalizadas"
                  data-action="click->referral-messages#switchTab"
                  class="py-2 px-4 border-b-2 font-medium text-sm transition-all border-transparent text-gray-500 hover:text-gray-700 hover:border-gray-300 cursor-pointer">
            Personalizadas
          </button>
        </nav>
      </div>
    </div>

    <% if @show_automation_channel_ui %>
      <div class="mb-4 flex gap-2">
        <button type="button"
                data-lead-messages-automation-target="evolutionTab"
                data-action="click->lead-messages-automation#switchChannelTab"
                data-channel="evolution"
                class="px-3 py-1.5 text-sm rounded border font-medium">
          Evolution (texto/mídia)
        </button>
        <button type="button"
                data-lead-messages-automation-target="metaTab"
                data-action="click->lead-messages-automation#switchChannelTab"
                data-channel="meta"
                class="px-3 py-1.5 text-sm rounded border font-medium">
          Meta (templates)
        </button>
      </div>
    <% end %>

    <div data-referral-messages-target="tabContent" data-tab-name="globais">
      <div data-lead-messages-automation-target="evolutionPanel">
        <p class="text-sm text-gray-600 mb-4">
          Mensagens de sistema (Confirmação, Remarcação, Lembrete, etc.) enviadas via WhatsApp próprio quando o canal da conta está em Evolution ou quando o slot tem mídia.
          <%= can_manage_lead_messages? ? 'Você pode editá-las.' : 'Apenas operadores e gerentes podem editar estas mensagens.' %>
        </p>
        <% globais = @messages.select { |m| m.message_type != 'outro' } %>
        <% if @viewing_all_externals && @messages_by_location.present? %>
          <% @messages_by_location.each do |location, location_messages| %>
            <% loc_globais = location_messages.select { |m| m.message_type != 'outro' } %>
            <div class="mb-8">
              <h6 class="text-lg font-semibold text-gray-800 mb-3 pb-2 border-b border-gray-200"><%= location.name %></h6>
              <% if loc_globais.any? %>
                <%= render partial: 'messages_table', locals: { messages_to_show: loc_globais, show_type_column: true, show_meta_column: false } %>
              <% else %>
                <p class="text-sm text-gray-500 italic">Nenhuma mensagem de sistema.</p>
              <% end %>
            </div>
          <% end %>
        <% elsif globais.any? %>
          <%= render partial: 'messages_table', locals: { messages_to_show: globais, show_type_column: true, show_meta_column: false } %>
        <% else %>
          <p class="text-sm text-gray-500 italic">Nenhuma mensagem de sistema.</p>
        <% end %>
      </div>

      <% if @show_automation_channel_ui %>
        <div data-lead-messages-automation-target="metaPanel" style="display: none;">
          <% if @meta_automation_viewing_all_externals && @meta_automation_by_location.present? %>
            <% @meta_automation_by_location.each_with_index do |(location, enabled_map), index| %>
              <div class="mb-8">
                <h6 class="text-lg font-semibold text-gray-800 mb-3 pb-2 border-b border-gray-200"><%= location.name %></h6>
                <%= render partial: "meta_automation_templates",
                           locals: {
                             templates_by_purpose: @clinic_meta_automation_by_purpose,
                             clinic_automation_channel: @clinic_automation_channel,
                             service_location_id: location.id,
                             location_label: location.name,
                             enabled_map: enabled_map,
                             hide_intro: index > 0
                           } %>
              </div>
            <% end %>
          <% else %>
            <%= render partial: "meta_automation_templates",
                       locals: {
                         templates_by_purpose: @clinic_meta_automation_by_purpose,
                         clinic_automation_channel: @clinic_automation_channel,
                         service_location_id: @meta_automation_service_location_id,
                         location_label: @meta_automation_location_label,
                         enabled_map: @meta_automation_enabled_map
                       } %>
          <% end %>
        </div>
      <% end %>
    </div>

    <div data-referral-messages-target="tabContent" data-tab-name="personalizadas" style="display: none;">
      <p class="text-sm text-gray-600 mb-4">Mensagens personalizadas que você criou. Você pode editar e excluir estas mensagens.</p>
      <% if @viewing_all_externals && @messages_by_location.present? %>
        <% @messages_by_location.each do |location, location_messages| %>
          <% personalizadas = location_messages.select { |m| m.message_type == 'outro' } %>
          <div class="mb-8">
            <h6 class="text-lg font-semibold text-gray-800 mb-3 pb-2 border-b border-gray-200"><%= location.name %></h6>
            <% if personalizadas.any? %>
              <%= render partial: 'messages_table', locals: {
                    messages_to_show: personalizadas,
                    show_type_column: false,
                    show_meta_column: false
                  } %>
            <% else %>
              <p class="text-sm text-gray-500 italic">Nenhuma mensagem personalizada.</p>
            <% end %>
          </div>
        <% end %>
      <% else %>
        <% personalizadas = @messages.select { |m| m.message_type == 'outro' } %>
        <%= render partial: 'messages_table', locals: {
              messages_to_show: personalizadas,
              show_type_column: false,
              show_meta_column: false
            } %>
      <% end %>
    </div>
  </div>
<% end %>

<%# Button to create a new message %>
<div class="mt-8">
  <%= link_to 'Criar Nova Mensagem Customizada', new_lead_message_path, class: "px-4 py-2 bg-blue-500 text-white rounded hover:bg-blue-600" %>
</div>
