<div class="flex flex-wrap">
  <div class="w-full md:w-1/2 p-2">
    <%= form_with(model: message, local: true) do |form| %>
      <% if message.errors.any? %>
        <div id="error_explanation" class="bg-red-100 border border-red-400 text-red-700 px-4 py-3 rounded relative" role="alert">
          <strong class="font-bold"><%= pluralize(message.errors.count, "erro") %> encontrado(s):</strong>
          <ul class="list-disc list-inside">
            <% message.errors.full_messages.each do |message| %>
              <li><%= message %></li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <div class="field mb-4">
        <%= form.label :name, "Nome da mensagem", class: "block text-gray-700 text-sm font-bold mb-2" %>
        <%= form.text_field :name, class: "shadow appearance-none border rounded w-full py-2 px-3 text-gray-700 leading-tight focus:outline-none focus:shadow-outline" %>
      </div>

      <% if !referral?(current_user) && is_manager_above? %>
        <div class="field mb-4">
          <%= form.label :message_type, "Tipo da mensagem", class: "block text-gray-700 text-sm font-bold mb-2" %>
          <%= form.select :message_type, ClinicManagement::LeadMessage.message_types.map { |key, value| [key.humanize, key] }, {}, { class: "shadow appearance-none border rounded w-full py-2 px-3 text-gray-700 leading-tight focus:outline-none focus:shadow-outline" } %>
        </div>
      <% end %>

      <%# ESSENTIAL: Service location select when multi-regions enabled.
          Default = current navbar selection. If "Todos" selected, prompt + validation required. %>
      <% if multi_service_locations_enabled? && !referral?(current_user) %>
        <div class="field mb-4">
          <%= form.label :service_location_id, "Local da mensagem", class: "block text-gray-700 text-sm font-bold mb-2" %>
          <%= form.select :service_location_id,
              options_for_select(
                lead_message_service_location_options,
                lead_message_default_service_location_id
              ),
              { prompt: require_service_location_selection? ? "Selecione um local (obrigatório)" : "Selecione um local" },
              { class: "shadow appearance-none border rounded w-full py-2 px-3 text-gray-700 leading-tight focus:outline-none focus:shadow-outline" } %>
          <% if message.errors[:service_location_id].any? %>
            <p class="text-red-600 text-sm mt-1"><%= message.errors[:service_location_id].first %></p>
          <% end %>
          <p class="text-xs text-gray-500 mt-1">
            Interno = mensagem para atendimentos locais. Escolha o local para mensagens específicas (ex: endereço da Ótica).
          </p>
        </div>
      <% end %>

      <% service_types = ClinicManagement::ServiceType.where(removed: false).order(:name) %>
      <% if service_types.count > 1 %>
        <div class="field mb-4">
          <%= form.label :service_type_id, "Tipo de serviço", class: "block text-gray-700 text-sm font-bold mb-2" %>
          <%= form.collection_select :service_type_id, service_types, :id, :name, { prompt: "Selecione um tipo de serviço", selected: service_types.first&.id }, { class: "shadow appearance-none border rounded w-full py-2 px-3 text-gray-700 leading-tight focus:outline-none focus:shadow-outline" } %>
        </div>
      <% else %>
        <%# Se houver apenas 1 tipo de serviço, não mostrar o campo %>
        <%= form.hidden_field :service_type_id, value: service_types.first&.id %>
        <div class="mb-4 px-3 py-2 bg-blue-50 border border-blue-200 rounded text-blue-800 text-sm">
          <strong>Tipo de serviço:</strong> <%= service_types.first&.name %>
        </div>
      <% end %>

      <div class="field mb-4" data-controller="emoji-picker">
        <%= form.label :text, "Texto da mensagem", class: "block text-gray-700 text-sm font-bold mb-2" %>
        <%= form.text_area :text, rows: 20, class: "shadow appearance-none border rounded w-full py-2 px-3 text-gray-700 leading-tight focus:outline-none focus:shadow-outline", data: { emoji_picker_target: "input" } %>
        <%# Emoji picker panel: click inserts emoji at cursor position in the textarea above %>
        <div class="mt-2 p-3 bg-gray-50 border border-gray-200 rounded-lg">
          <p class="text-sm font-medium text-gray-700 mb-2">Inserir emoji no texto:</p>
          <div class="flex flex-wrap gap-1" role="group" aria-label="Emojis para inserir na mensagem">
            <% %w[😀 😃 😄 😁 😅 😂 🤣 😊 🙂 🙃 😉 😌 😍 🥰 😘 😗 😙 😚 😋 😛 😜 🤪 😝 🤑 🤗 🤭 🤫 🤔 🤐 🤨 😐 😑 😶 😏 😣 😥 😮 🤐 😯 😪 😫 😴 🤤 😷 🤒 🤕 🤢 🤮 🤧 🥵 🥶 🥴 😵 🤯 🤠 🥳 😎 🤓 😈 👋 🤚 🖐 ✋ 🖖 👌 🤌 🤏 ✌️ 🤞 🤟 🤘 🤙 👈 👉 👆 🖕 👇 ☝️ 👍 👎 ✊ 👊 🤛 🤜 👏 🙌 👐 🤲 🤝 🙏 💪 ❤️ 🧡 💛 💚 💙 💜 🖤 🤍 🤎 💔 ❣️ 💕 💞 💓 💗 💖 💘 💝 💟 ☮️ ✝️ ☪️ 🕉 ☸️ ✡️ 🔯].each do |emoji| %>
              <button type="button"
                      class="text-xl p-1.5 rounded hover:bg-gray-200 focus:bg-gray-200 focus:outline-none focus:ring-2 focus:ring-blue-500"
                      data-emoji="<%= emoji %>"
                      data-action="click->emoji-picker#insert"
                      title="Inserir <%= emoji %>"
                      aria-label="Inserir emoji <%= emoji %>"><%= emoji %></button>
            <% end %>
          </div>
        </div>
      </div>

      <!-- Seção de Anexo de Mídia -->
      <div class="border-t pt-4 mb-4">
        <h3 class="text-lg font-semibold text-gray-700 mb-3">Anexar Arquivo de Mídia (Opcional)</h3>
        <p class="text-sm text-gray-600 mb-4">
          <strong>Importante:</strong> Para imagens e áudios, apenas o arquivo com legenda será enviado (sem o texto da mensagem). 
          Para vídeos e PDFs, tanto o arquivo quanto o texto serão enviados.
        </p>
        
        <div class="field mb-4">
          <%= form.label :media_file, "Arquivo (Imagem, Áudio, Vídeo ou PDF)", class: "block text-gray-700 text-sm font-bold mb-2" %>
          <%= form.file_field :media_file, 
                accept: "image/*,audio/*,video/*,application/pdf,audio/opus", 
                class: "block w-full text-sm text-gray-500 file:mr-4 file:py-2 file:px-4 file:rounded-full file:border-0 file:text-sm file:font-semibold file:bg-blue-50 file:text-blue-700 hover:file:bg-blue-100" %>
          <p class="text-xs text-gray-500 mt-1">
            Formatos aceitos: JPG, PNG, GIF, WebP, MP3, WAV, OGG, OPUS, M4A, MP4, AVI, MOV, WMV, WebM, PDF
          </p>
        </div>

        <div class="field mb-4">
          <%= form.label :media_caption, "Legenda do arquivo (opcional)", class: "block text-gray-700 text-sm font-bold mb-2" %>
          <%= form.text_area :media_caption, rows: 3, 
                placeholder: "Digite uma legenda para o arquivo...",
                class: "shadow appearance-none border rounded w-full py-2 px-3 text-gray-700 leading-tight focus:outline-none focus:shadow-outline" %>
          <p class="text-xs text-gray-500 mt-1">
            Para imagens e áudios: se não informar legenda, o texto da mensagem será usado como legenda.
          </p>
        </div>
      </div>

      <div class="actions">
        <%= form.submit "Salvar Mensagem", class: "bg-blue-500 hover:bg-blue-700 text-white font-bold py-2 px-4 rounded" %>
      </div>
    <% end %>
  </div>

  <div class="w-full md:w-1/2 p-2">
    <%= render "instructions" %>
  </div>
</div>