<div class="my-8">
  <h5 class="text-2xl font-bold">Editar mensagem customizada</h5>
  <% if @meta_template.present? %>
    <p class="text-sm text-gray-700 mt-2">
      Status Meta:
      <%= render partial: "shared/meta_template_source_status",
                 locals: { source: @message, meta_template: @meta_template } %>
    </p>
  <% elsif current_account&.meta_whatsapp_enabled? && current_account.meta_inbox_operational? && @message.referral_id.nil? %>
    <p class="text-sm text-gray-600 mt-2">
      Ao salvar, o texto será enviado automaticamente para aprovação como template na Meta.
    </p>
  <% end %>
</div>

<%= render 'form', message: @message %>

<div class="mt-8">
  <%= link_to 'Voltar', lead_messages_path, class: "px-4 py-2 bg-gray-500 text-white rounded" %>
</div>
