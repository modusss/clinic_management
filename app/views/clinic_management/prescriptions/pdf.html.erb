<!DOCTYPE html>
<html>
<head>
  <title>Receita de Lentes</title>
  <style>
    body {
      font-family: Arial, sans-serif; 
      margin: 0; 
      padding: 0; 
      line-height: 1.6;
    }
    h1 {
      text-align: center; 
      margin-top: 40px; 
      margin-bottom: 20px;
    }
    .description, .note, .contact-info {
      margin: 0 20px 20px 20px;
    }
    table {
      width: 90%; 
      margin: 0 auto 20px auto; 
      border-collapse: collapse;
    }
    th, td {
      border: 1px solid #ddd; 
      padding: 10px; 
      text-align: center;
    }
    th {
      background-color: #f2f2f2; 
      font-weight: bold;
    }
    .logo {
      display: block; 
      margin: 20px auto; 
      max-width: 200px; 
      max-height: 120px;
      width: auto;
      height: auto;
      object-fit: contain;
    }
    .clinic-name {
      font-size: 18px;
      margin: 20px auto;
      text-align: center;
    }
    .qr_code {
      text-align: center; 
      margin: 0 auto;
    }
    .footer-text {
      margin-bottom: 5px;
    }
    .comment-info {
      margin-top: 12px;
    }
    .trix-content {
      margin: 0;
      line-height: 1.6;
    }
    .trix-content p,
    .trix-content div {
      margin: 0 0 8px 0;
    }
    .trix-content strong {
      font-weight: bold;
    }
    .trix-content ul,
    .trix-content ol {
      margin: 0 0 8px 20px;
      padding: 0;
    }
    .rotate-text {
      transform: rotate(-90deg); 
      margin: 0;
    }
  </style>
</head>

<body>
      <br>

  <div class="header">
    <h1>Dados do Teste de Refração de Acuidade Visual</h1>
  </div>

  <div class="description mt-4">
    <p>Prezado(a) <%= @prescription.appointment.invitation.patient_name.split.first.upcase %>,</p>
    
    <p>
      Seguem abaixo os resultados do seu teste de vista. Esses valores indicam 
      as correções necessárias para a confecção das suas lentes de óculos.
    </p>
  </div>

  <table>
    <thead>
      <tr>
        <th></th>
        <th>ESFÉRICO</th>
        <th>CILINDRO</th>
        <th>EIXO</th>
        <th>ADIÇÃO</th>
      </tr>
    </thead>
    <tbody>
      <tr>
        <td>Direito (OD)</td>
        <% sr = @prescription.sphere_right.to_f %>
        <td><%= sr == 0 ? "--" : (sr > 0 ? "+" : "") + number_with_precision(sr, precision: 2, separator: ',') %></td>
        <td><%= @prescription.cylinder_right.to_f == 0 ? "--" : number_with_precision(@prescription.cylinder_right, precision: 2, separator: ',') || "--" %></td>
        <td><%= @prescription.axis_right.to_i == 0 ? "--" : (@prescription.axis_right || "--") %></td>
        <td><%= @prescription.add_right.to_f == 0 ? "--" : number_with_precision(@prescription.add_right, precision: 2, separator: ',') || "--" %></td>
      </tr>
      <tr>
        <td>Esquerdo (OE)</td>
        <% sl = @prescription.sphere_left.to_f %>
        <td><%= sl == 0 ? "--" : (sl > 0 ? "+" : "") + number_with_precision(sl, precision: 2, separator: ',') %></td>
        <td><%= @prescription.cylinder_left.to_f == 0 ? "--" : number_with_precision(@prescription.cylinder_left, precision: 2, separator: ',') || "--" %></td>
        <td><%= @prescription.axis_left.to_i == 0 ? "--" : (@prescription.axis_left || "--") %></td>
        <td><%= @prescription.add_left.to_f == 0 ? "--" : number_with_precision(@prescription.add_left, precision: 2, separator: ',') || "--" %></td>
      </tr>
    </tbody>
  </table>

  <div class="note">
    <%# ESSENTIAL: Guarantee paragraph — customizable in Organização > Preferências (Account#clinic_prescription_pdf_message). %>
    <div class="footer-text trix-content">
      <%= @account.clinic_prescription_pdf_message_html.html_safe %>
    </div>
    <br>
    <div class="date-info">
      <% prescription_date = @prescription.appointment.service&.date || @prescription.appointment.created_at&.to_date || Date.current %>
      <strong>Data:</strong> <%= prescription_date.strftime("%d/%m/%Y") %>
    </div>
    <%# ESSENTIAL: Prescription comment from receita form — must appear on printed guia when present. %>
    <% if @prescription.comment.present? %>
      <div class="comment-info">
        <p><strong>Comentário:</strong></p>
        <p><%= @prescription.comment %></p>
      </div>
    <% end %>
  </div>
    <br>
    <br>
  <div class="contact-info">
    <%# ESSENTIAL: Clinic branding — logo OR company_name (never both); CNPJ when set. %>
    <div style="text-align: center;">
      <% if @account&.clinic_logo&.attached? %>
        <% logo_data = active_storage_image_base64(@account.clinic_logo) %>
        <%= image_tag logo_data, class: "logo" if logo_data.present? %>
      <% elsif @company_contact&.company_name.present? %>
        <p class="clinic-name"><strong><%= @company_contact.company_name %></strong></p>
      <% end %>
    </div>

    <div style="text-align: center;">
      <% if @company_contact.present? %>
        <% if @company_contact.cnpj.present? %>
          <div>
            <strong>CNPJ:</strong> <%= @company_contact.cnpj %>
          </div>
        <% end %>
        <% if [@company_contact.phone1, @company_contact.street, @company_contact.city].any?(&:present?) %>
          <% if @company_contact.phone1.present? %>
            <div>
              <strong>Tel:</strong> <%= @company_contact.phone1 %><%= " | #{@company_contact.phone2}" if @company_contact.phone2.present? %>
            </div>
          <% end %>
          <% if @company_contact.street.present? %>
            <div>
              <%= @company_contact.street %><%= ", #{@company_contact.neighborhood}" if @company_contact.neighborhood.present? %>
            </div>
          <% end %>
          <% if @company_contact.city.present? || @company_contact.state.present? %>
            <div>
              <%= [@company_contact.city, @company_contact.state].compact.join("/") %>
            </div>
          <% end %>
        <% end %>
      <% end %>
    </div>
  </div>
</body>
</html>
