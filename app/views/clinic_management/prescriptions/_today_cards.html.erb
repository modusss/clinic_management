<%# Cards view for today's services and patients %>
<% rows.each_with_index do |rows, index| %>
  <% doctor_filter = rows.any? { |row| row.first&.dig(:attendance_status).present? } %>
  <div class="mb-8" <%= 'data-doctor-attendance-filter-target="period"'.html_safe if doctor_filter %>>
    <h3 class="text-xl text-gray-700 mb-3 px-4">
      <%= services[index].start_time.strftime('%H:%M') %>h às <%= services[index].end_time.strftime('%H:%M') %>h
    </h3>
    <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-4">
      <% if rows.any? %>
        <% rows.each do |row| %>
          <% attendance_status = row.first[:attendance_status] %>
          <div class="bg-white rounded shadow p-4 mb-4"
               <% if attendance_status.present? %>
                 data-doctor-attendance-filter-target="item"
                 data-attendance="<%= attendance_status %>"
               <% end %>>
            <% row.each do |cell| %>
              <div class="mb-2">
                <span class="block text-xs text-gray-500 font-semibold"><%= cell[:header] %></span>
                <span class="block text-base text-gray-800" style="margin-top: 10px;"><%= cell[:content] %></span>
              </div>
            <% end %>
          </div>
        <% end %>
        <% if doctor_filter %>
          <div data-doctor-attendance-filter-target="empty"
               class="hidden bg-white rounded shadow p-4 mb-4 col-span-full">
            <span class="block text-base text-gray-800">Nenhum paciente agendado</span>
          </div>
        <% end %>
      <% else %>
        <div class="bg-white rounded shadow p-4 mb-4">
          <span class="block text-base text-gray-800">Nenhum paciente agendado</span>
        </div>
      <% end %>
    </div>
  </div>
<% end %>
