<% service_types = ClinicManagement::ServiceType.where(removed: false).order(:name).to_a %>
<%= form_with model: time_slot,
              class: "bg-white shadow-md rounded px-8 pt-6 pb-8 mb-4",
              data: {
                controller: "booking-mode-fields",
                action: "change->booking-mode-fields#refresh"
              } do |form| %>
  <% if time_slot.errors.any? %>
    <div class="bg-red-100 border border-red-300 text-red-700 px-4 py-3 rounded mb-4" role="alert">
      <strong><%= pluralize(time_slot.errors.count, "erro") %> impediram que o horário fosse salvo:</strong>
      <ul class="list-disc list-inside mt-2">
        <% time_slot.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="mb-4">
    <%= form.label :weekday, "Dia da semana", class: "block text-gray-700 font-bold mb-2" %>
    <%= form.select :weekday,
          ["Domingo", "Segunda-feira", "Terça-feira", "Quarta-feira", "Quinta-feira", "Sexta-feira", "Sábado"],
          { selected: show_week_day(time_slot.weekday), prompt: "Selecione um dia" },
          class: "appearance-none border rounded w-full py-2 px-3 text-gray-700 leading-tight focus:outline-none focus:shadow-outline" %>
  </div>

  <% [
       [:start_time, "Início"],
       [:end_time, "Fim"]
     ].each do |attribute, label| %>
    <% value = time_slot.public_send(attribute) %>
    <div class="mb-4">
      <%= form.label attribute, label, class: "block text-gray-700 font-bold mb-2" %>
      <%= form.text_field attribute,
            value: value.respond_to?(:strftime) ? value.strftime("%H:%M") : value,
            placeholder: "Ex: 16:00 ou 16h",
            class: "appearance-none border rounded w-full py-2 px-3 text-gray-700 leading-tight focus:outline-none focus:shadow-outline",
            data: {
              controller: "time-24h",
              action: "input->time-24h#autoComplete blur->time-24h#normalize"
            } %>
    </div>
  <% end %>

  <div class="mb-4">
    <%= form.label :booking_mode, "Forma de atendimento", class: "block text-gray-700 font-bold mb-2" %>
    <%= form.select :booking_mode,
          [["Ordem de chegada", "arrival_order"], ["Horário agendado", "scheduled"]],
          {},
          class: "appearance-none border rounded w-full py-2 px-3 text-gray-700 leading-tight focus:outline-none focus:shadow-outline" %>
  </div>

  <div class="mb-4" data-booking-mode-fields-interval-container>
    <%= form.label :interval_minutes, "Intervalo dos horários", class: "block text-gray-700 font-bold mb-2" %>
    <%= form.select :interval_minutes,
          [["10 minutos", 10], ["15 minutos", 15], ["20 minutos", 20], ["30 minutos", 30], ["1 hora", 60]],
          { prompt: "Selecione o intervalo" },
          class: "appearance-none border rounded w-full py-2 px-3 text-gray-700 leading-tight focus:outline-none focus:shadow-outline" %>
  </div>

  <% if service_types.size > 1 %>
    <fieldset class="mb-5 rounded-lg border border-gray-200 p-4" data-booking-mode-fields-service-types>
      <legend class="px-2 text-gray-700 font-bold">Tipos de atendimento</legend>
      <label class="flex items-center gap-3 cursor-pointer">
        <%= form.check_box :all_service_types,
              { checked: time_slot.new_record? ? true : time_slot.all_service_types?,
                data: { booking_mode_fields_all_types: true } },
              "1",
              "0" %>
        <span>
          <strong class="block text-gray-800">Aplica-se a todos os tipos</strong>
          <small class="block text-gray-500">Padrão recomendado: este horário ficará disponível para qualquer tipo atual ou criado futuramente.</small>
        </span>
      </label>

      <div class="mt-4 grid grid-cols-1 sm:grid-cols-2 gap-3" data-booking-mode-fields-specific-types>
        <%= form.collection_check_boxes :service_type_ids, service_types, :id, :name do |item| %>
          <%= item.label class: "flex items-center gap-2 rounded border border-gray-200 px-3 py-2 cursor-pointer" do %>
            <%= item.check_box %>
            <span><%= item.text %></span>
          <% end %>
        <% end %>
      </div>
    </fieldset>
  <% else %>
    <%= form.hidden_field :all_service_types, value: "1" %>
  <% end %>

  <%= form.submit time_slot.new_record? ? "Criar novo horário de atendimento" : "Atualizar horário de atendimento",
        class: "bg-blue-500 hover:bg-blue-700 text-white font-bold py-2 px-4 rounded mt-4" %>
<% end %>
