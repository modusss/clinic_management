<% form_fields = [
  {type: 'select', selected: show_week_day(time_slot.weekday), input: :weekday, name: 'Dia da semana', options: ['Domingo', 'Segunda-feira', 'Terça-feira', 'Quarta-feira', 'Quinta-feira', 'Sexta-feira', 'Sábado']},
  {type: 'time_24h', input: :start_time, name: 'Início', placeholder: 'Ex: 16:00 ou 16h'},
  {type: 'time_24h', input: :end_time, name: 'Fim', placeholder: 'Ex: 16:00 ou 16h'},
  {type: 'select', selected: time_slot.booking_mode, input: :booking_mode, name: 'Forma de atendimento', options: [['Ordem de chegada', 'arrival_order'], ['Horário agendado', 'scheduled']]},
  {type: 'select', selected: time_slot.interval_minutes, input: :interval_minutes, name: 'Intervalo dos horários', options: [['10 minutos', 10], ['15 minutos', 15], ['20 minutos', 20], ['30 minutos', 30], ['1 hora', 60]]}
] %>
<%= standardized_form_for(
      time_slot,
      form_fields,
      submit_label_create: "Criar novo horário de atendimento",
      submit_label_update: "Atualizar horário de atendimento",
      html: {
        data: {
          controller: "booking-mode-fields",
          action: "change->booking-mode-fields#refresh"
        }
      }
    ) %>
