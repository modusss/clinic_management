<%= breadcrumb({title: "Locais de Atendimento", path: service_locations_path}, {title: @service_location.name, path: nil}) %>
<div class="my-8">
  <h1 class="text-2xl font-bold mb-4"><%= @service_location.name %></h1>
  <p class="text-gray-600">Time Slots: <%= @service_location.time_slots.count %></p>
  <p class="text-gray-600">Services: <%= @service_location.services.count %></p>
  <%= link_to "Editar", edit_service_location_path(@service_location), class: "text-blue-500 hover:underline" %>
</div>
