<%= form_with model: @service_location, url: @service_location.persisted? ? service_location_path(@service_location) : service_locations_path, method: @service_location.persisted? ? :patch : :post, local: true, class: "space-y-4" do |f| %>
  <% if @service_location.errors.any? %>
    <div class="rounded-md bg-red-50 p-4">
      <ul class="list-disc list-inside text-sm text-red-700">
        <% @service_location.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div>
    <%= f.label :name, "Nome", class: "block text-sm font-medium text-gray-700 mb-1" %>
    <%= f.text_field :name, class: "block w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500", placeholder: "ex: Ótica Centro, Atendimento Shopping" %>
  </div>

  <%# ESSENTIAL: Indicators allowed to use this external location. Unchecked = cannot see/use. %>
  <% if defined?(@active_referrals) && @active_referrals.present? %>
    <div class="border-t pt-4 mt-4">
      <h3 class="text-sm font-medium text-gray-700 mb-2">Indicadores que podem lançar neste local</h3>
      <p class="text-lg text-gray-500 mb-3">Marque os indicadores ativos que podem ver e usar este local externo no formulário de novo convite. Se nenhum for marcado, apenas usuários não-indicadores verão este local.</p>
      <div class="space-y-2 max-h-48 overflow-y-auto rounded border border-gray-200 p-3 bg-gray-50">
        <% @active_referrals.each do |ref| %>
          <label class="flex items-center gap-2 cursor-pointer hover:bg-gray-100 p-2 rounded">
            <%= check_box_tag "service_location[referral_ids][]", ref.id, @service_location.referral_ids.include?(ref.id), class: "rounded border-gray-300" %>
            <span class="text-sm text-gray-700"><%= ref.name %></span>
          </label>
        <% end %>
      </div>
      <%= hidden_field_tag "service_location[referral_ids][]", "" %>
    </div>
  <% end %>

  <%# ESSENTIAL: Doctors allowed to see this location in "atendimento de hoje" menu. Unchecked = cannot see. %>
  <% if defined?(@active_doctors) && @active_doctors.present? %>
    <div class="border-t pt-4 mt-4">
      <h3 class="text-sm font-medium text-gray-700 mb-2">Doutores que podem ver este local</h3>
      <p class="text-lg text-gray-500 mb-3">Marque os doutores que podem ver e usar este local externo no menu de atendimento de hoje. Se nenhum for marcado, apenas usuários não-doutores verão este local no seletor.</p>
      <div class="space-y-2 max-h-48 overflow-y-auto rounded border border-gray-200 p-3 bg-gray-50">
        <% @active_doctors.each do |doc| %>
          <label class="flex items-center gap-2 cursor-pointer hover:bg-gray-100 p-2 rounded">
            <%= check_box_tag "service_location[allowed_doctor_ids][]", doc.id, @service_location.allowed_doctor_ids.include?(doc.id), class: "rounded border-gray-300" %>
            <span class="text-sm text-gray-700"><%= doc.name %></span>
          </label>
        <% end %>
      </div>
      <%= hidden_field_tag "service_location[allowed_doctor_ids][]", "" %>
    </div>
  <% end %>

  <div class="flex gap-2">
    <%= f.submit @service_location.persisted? ? "Atualizar Local de Atendimento" : "Criar Local de Atendimento", class: "inline-flex justify-center rounded-md border border-transparent bg-blue-600 py-2 px-4 text-sm font-medium text-white shadow-sm hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-offset-2" %>
    <%= link_to "Cancelar", service_locations_path, class: "inline-flex justify-center rounded-md border border-gray-300 bg-white py-2 px-4 text-sm font-medium text-gray-700 shadow-sm hover:bg-gray-50" %>
  </div>
<% end %>
