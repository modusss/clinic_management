<%= form_with model: @service_location, url: @service_location.persisted? ? service_location_path(@service_location) : service_locations_path, method: @service_location.persisted? ? :patch : :post, local: true, class: "space-y-4" do |f| %>
  <% if @service_location.errors.any? %>
    <div class="rounded-md bg-red-50 p-4">
      <ul class="list-disc list-inside text-sm text-red-700">
        <% @service_location.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div>
    <%= f.label :name, "Nome", class: "block text-sm font-medium text-gray-700 mb-1" %>
    <%= f.text_field :name, class: "block w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500", placeholder: "ex: Ótica Centro, Atendimento Shopping" %>
  </div>

  <div class="flex items-center">
    <%= f.check_box :is_default, class: "rounded border-gray-300" %>
    <%= f.label :is_default, "Marcar como padrão (opcional)", class: "ml-2 text-sm text-gray-700" %>
  </div>

  <div class="flex gap-2">
    <%= f.submit class: "inline-flex justify-center rounded-md border border-transparent bg-blue-600 py-2 px-4 text-sm font-medium text-white shadow-sm hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-offset-2" %>
    <%= link_to "Cancelar", service_locations_path, class: "inline-flex justify-center rounded-md border border-gray-300 bg-white py-2 px-4 text-sm font-medium text-gray-700 shadow-sm hover:bg-gray-50" %>
  </div>
<% end %>
