<% content_for :footer, @company_name.presence || "Clínica" %>

<%= stylesheet_link_tag "commission_dashboard", "data-turbo-track": "reload" %>

<div class="max-w-6xl mx-auto mb-8">
  <nav class="text-sm text-emerald-800 mb-4" aria-label="Breadcrumb">
    <%= link_to "Indicadores", referral_indicators_path, class: "hover:underline" %>
    <span class="mx-1">/</span>
    <span class="text-gray-600">Comissões — <%= @referral.name %></span>
  </nav>

  <% if @referral.commission_type == "percentage" %>
    <%= render "/commissions/commission_percentage" %>
  <% else %>
    <%= render "clinic_management/referral_commissions/unit_dashboard" %>
  <% end %>
</div>
