<% content_for :footer, @company_name.presence || "Clínica" %>

<div class="max-w-4xl mx-auto">
  <nav class="text-sm text-emerald-800 mb-4" aria-label="Breadcrumb">
    <%= link_to "Indicadores", referral_indicators_path, class: "hover:underline" %>
    <span class="mx-1">/</span>
    <%= link_to @referral.name, commissions_referral_indicator_path(@referral), class: "hover:underline" %>
    <span class="mx-1">/</span>
    <span class="text-gray-600">Pagamentos recebidos</span>
  </nav>

  <div class="bg-white rounded-xl shadow-md border border-gray-200 overflow-hidden">
    <div class="bg-gradient-to-r from-emerald-800 to-emerald-700 px-6 py-4">
      <h1 class="text-xl font-semibold text-white">Pagamentos — <%= @referral.name %></h1>
    </div>
    <div class="p-6">
      <% if @commission_payouts.any? %>
        <div class="overflow-x-auto rounded-lg border border-gray-200">
          <table class="min-w-full divide-y divide-gray-200 text-sm">
            <thead class="bg-gray-50">
              <tr>
                <th class="px-4 py-3 text-left font-semibold text-gray-700">Data</th>
                <th class="px-4 py-3 text-right font-semibold text-gray-700">Valor</th>
                <th class="px-4 py-3 text-right font-semibold text-gray-700">Itens</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-gray-100">
              <% @commission_payouts.each do |payout| %>
                <tr>
                  <td class="px-4 py-3"><%= payout.created_at.strftime("%d/%m/%Y") %></td>
                  <td class="px-4 py-3 text-right font-medium"><%= currency_br(payout.total_amount) %></td>
                  <td class="px-4 py-3 text-right"><%= payout.commission_payments.count %></td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
        <div class="flex justify-center pt-4"><%= paginate(@commission_payouts) %></div>
      <% else %>
        <p class="text-center text-gray-600 py-6">Nenhum pagamento registrado.</p>
      <% end %>
    </div>
  </div>
</div>
