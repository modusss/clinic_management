<%# ESSENTIAL: Unit (fixed) commission dashboard — Tailwind wrapper for clinic-only mode. %>
<div class="bg-white rounded-xl shadow-md border border-gray-200 overflow-hidden">
  <div class="bg-gradient-to-r from-emerald-800 to-emerald-700 px-6 py-4">
    <h1 class="text-xl font-semibold text-white">Indicações de <%= @referral.name %></h1>
  </div>

  <div class="p-6 space-y-6">
    <div class="flex flex-wrap gap-3">
      <%= link_to "Novo convite", clinic_management.new_invitation_path,
          class: "inline-flex items-center rounded-lg bg-emerald-700 hover:bg-emerald-800 text-white font-medium px-4 py-2 transition-colors" %>
      <%= link_to "Marcações", clinic_management.index_by_referral_services_path(@referral),
          class: "inline-flex items-center rounded-lg bg-emerald-600 hover:bg-emerald-700 text-white font-medium px-4 py-2 transition-colors" %>
    </div>

    <ul class="grid grid-cols-1 sm:grid-cols-3 gap-3 text-sm">
      <li class="rounded-lg border border-gray-200 bg-gray-50 px-4 py-3">Comissões recebidas: <strong><%= @paid_commissions %></strong></li>
      <li class="rounded-lg border border-gray-200 bg-gray-50 px-4 py-3">Comissões pendentes: <strong><%= @pending_commissions %></strong></li>
      <li class="rounded-lg border border-gray-200 bg-gray-50 px-4 py-3">Aguardando entrega: <strong><%= @waiting_commissions %></strong></li>
    </ul>

    <nav class="flex flex-wrap gap-2 border-b border-gray-200 pb-2 text-sm" aria-label="Abas de comissão">
      <% [
        ["Comissão pendente", commissions_referral_indicator_path(@referral, status: "PENDING")],
        ["Aguardando entrega", commissions_referral_indicator_path(@referral, status: "WAITING")],
        ["Comissão paga", commissions_referral_indicator_path(@referral, status: "PAID")],
        ["Histórico de Pagamentos", payment_history_referral_indicator_path(@referral)]
      ].each do |label, url| %>
        <% active = request.path == url.split("?").first || (label == "Comissão pendente" && params[:status].blank?) %>
        <%= link_to label, url,
            class: "px-3 py-1.5 rounded-md #{active ? 'bg-emerald-700 text-white' : 'text-emerald-800 hover:bg-emerald-50'}" %>
      <% end %>
    </nav>

    <p class="text-gray-700">
      <span class="font-semibold"><%= @commissions_count %></span>
      <%= @commissions_count == 1 ? "cliente encontrado" : "clientes encontrados" %>
    </p>

    <% if is_manager_above? && @pending_commissions.to_i > 0 && (params[:status].blank? || params[:status] == "PENDING") %>
      <%= button_to "Definir como pago todas as #{@pending_commissions} comissões de #{@referral.name}",
          set_all_commissions_as_paid_referral_indicator_path(@referral),
          method: :put,
          class: "inline-flex items-center rounded-lg bg-green-600 hover:bg-green-700 text-white font-medium px-4 py-2 transition-colors",
          data: { turbo_confirm: "Tem certeza que deseja marcar todas como pagas?" } %>
    <% end %>

    <% if @commissions.present? %>
      <div class="overflow-x-auto rounded-lg border border-gray-200">
        <%= render "/commissions/commissions_table", commissions: @commissions %>
      </div>
      <div class="flex justify-center pt-4">
        <%= paginate(@commissions) %>
      </div>
    <% end %>
  </div>
</div>
