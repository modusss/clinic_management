<%# ESSENTIAL: Active/inactive grouping mirrors referral_indicators#index and referrals#index (Referral#active?). %>
<section>
  <header class="mb-4">
    <h1 class="text-2xl font-bold text-gray-900"><%= referral_capturers_label %></h1>
    <p class="text-gray-600">Clique em um captador para visualizar suas marcações.</p>
    <p class="text-sm text-gray-600 mt-2">
      <span class="inline-flex items-center gap-1 text-green-700 font-semibold">
        <i class="fas fa-check-circle" aria-hidden="true"></i>
        <%= @active_referrals.count %> <%= referral_capturer_active_count_label(@active_referrals.count) %>
      </span>
      <span class="mx-2 text-gray-400">·</span>
      Total: <strong><%= @referrals.count %></strong> <%= referral_capturers_label.downcase %>
    </p>
  </header>

  <% if @referrals.empty? %>
    <div class="text-center mt-8 py-4 border border-gray-300 rounded-lg">
      <p class="text-gray-600">Nenhum captador encontrado. Vamos criar alguns!</p>
    </div>
  <% else %>
    <% if @active_referrals.any? %>
      <%= render "clinic_management/services/referral_booking_cards", referrals: @active_referrals %>
    <% else %>
      <div class="text-center py-8 border border-gray-200 rounded-lg bg-gray-50">
        <p class="text-gray-600">Nenhum captador ativo no momento.</p>
      </div>
    <% end %>

    <% if @inactive_referrals.any? %>
      <details class="mt-6 bg-white rounded-lg border border-gray-200 overflow-hidden group">
        <summary class="cursor-pointer list-none px-4 py-3 bg-gray-50 flex flex-wrap items-center justify-between gap-2">
          <span class="font-medium text-gray-700">
            <i class="fas fa-chevron-down group-open:rotate-180 transition-transform mr-2 text-emerald-700" aria-hidden="true"></i>
            <i class="fas fa-user-slash text-gray-400 mr-1" aria-hidden="true"></i>
            <%= @inactive_referrals.count %> <%= referral_capturer_inactive_count_label(@inactive_referrals.count) %>
            <span class="text-gray-500 font-normal text-sm">(sem usuário associado)</span>
          </span>
          <span class="text-gray-400 text-sm">Clique para expandir</span>
        </summary>
        <div class="p-4 border-t border-gray-100">
          <p class="text-amber-800 bg-amber-50 border border-amber-200 rounded-lg px-4 py-3 text-sm mb-4">
            <% if clinic_only_referrals_ui? %>
              Para reativar, vá em <strong>Organização → Adicionar cooperador</strong> e selecione "Reintegrar captador existente".
            <% else %>
              Para reativar, vá em <strong>Configurações → Adicionar cooperador</strong> e selecione "Reintegrar captador existente".
            <% end %>
          </p>
          <%= render "clinic_management/services/referral_booking_cards", referrals: @inactive_referrals %>
        </div>
      </details>
    <% end %>
  <% end %>
</section>
