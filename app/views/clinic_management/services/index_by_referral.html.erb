<% if referral? current_user %>
  <%= breadcrumb({title: "Painel de conversões", path: main_app.referral_path(user_referral)},  {title: "Atendimentos de " + @referral.name, path: nil}) %>
<% else %>
<%= breadcrumb({title: "Todos os atendimentos", path: services_path}, {title: "Atendimentos de " + @referral.name, path: nil}) %>
<% end %>

<div class="container mt-6">
  <% if notice %>
    <div class="mb-4 p-2 bg-green-100 border border-green-500 text-green-700 rounded">
      <p><%= notice %></p>
    </div>
  <% end %>

  <section class="mb-8">
    <header class="flex items-center justify-between mb-4">
      <h1 class="text-2xl font-bold">Atendimentos de <%= @referral.name %></h1>
    </header>

    <% if is_manager_above? %>
    <!-- Filter Section -->
    <div class="mb-6 p-4 bg-gray-50 rounded-lg border">
      <div class="flex items-center space-x-4">
        <label for="view_type" class="text-sm font-medium text-gray-700">Visualização:</label>
        <%= form_with url: index_by_referral_services_path(referral_id: @referral.id), method: :get, local: true, class: "flex items-center space-x-2", id: "view-type-form-referral" do |form| %>
          <%= form.select :view_type, 
                options_for_select([
                  ['Diária (padrão)', 'daily'],
                  ['Semanal', 'weekly'],
                  ['Mensal', 'monthly']
                ], @view_type), 
                {}, 
                { 
                  class: "px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500",
                  onchange: "showLoadingAndSubmit(this);",
                  id: "view_type_select_referral"
                } %>
        <% end %>
        <div class="text-sm text-gray-600">
          <% case @view_type %>
          <% when 'weekly' %>
            Dados agrupados por semana (20 semanas por página)
          <% when 'monthly' %>
            Dados agrupados por mês — selecione o ano
          <% else %>
            Dados detalhados por dia
          <% end %>
        </div>
      </div>
      <%= render "clinic_management/services/year_filter_chips", referral: @referral %>
    </div>
    <% end %>

    <!-- Loading Notification -->
    <div id="loading-notification" class="fixed top-4 right-4 z-50 bg-white p-4 rounded-lg shadow-lg border-l-4 border-blue-500 flex items-center space-x-3" style="display: none;">
      <div class="loading-spinner"></div>
      <div>
        <h4 class="text-sm font-semibold text-gray-900">Processando dados...</h4>
        <p class="text-xs text-gray-600">Organizando informações por <span id="loading-period">período</span></p>
      </div>
      <button onclick="hideLoadingNotification()" class="text-gray-400 hover:text-gray-600 ml-2">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
        </svg>
      </button>
    </div>

    <div class="overflow-hidden border-gray-200 sm:rounded-lg">
      <% if @aggregated_stats.present? %>
        <%= render "clinic_management/services/aggregated_stats_table",
                   stats: @aggregated_stats,
                   period_header: (@view_type == "weekly" ? "Período" : "Mês") %>
      <% else %>
        <%= data_table(@rows) %>
      <% end %>
    </div>
    <br>
    
    <% if @view_type != 'daily' && @chart_data.present? %>
      <%= render "clinic_management/services/services_chart",
                 chart_data: @chart_data,
                 chart_heading: "Gráfico de #{@view_type == 'weekly' ? 'Dados Semanais' : "Dados Mensais — #{@selected_year}"} - #{@referral.name}",
                 stats_title: "#{@view_type == 'weekly' ? 'Estatísticas Semanais' : "Estatísticas Mensais — #{@selected_year}"} - #{@referral.name}",
                 x_axis_label: (@view_type == 'weekly' ? 'Semanas' : 'Meses') %>
    <% end %>
    
    <% if @view_type == 'weekly' && @week_periods.present? %>
      <%= clinic_paginate @week_periods, params: { view_type: @view_type } %>
    <% elsif @view_type == 'daily' && @services.present? %>
      <%= clinic_paginate @services %>
    <% end %>
  </section>

  <% if show_services_referrals_nav? && @referrals.present? %>
    <section class="mt-10 pt-8 border-t border-gray-200">
      <%= render "clinic_management/services/referrals_section",
                 current_referral: @referral,
                 link_params: referrals_nav_link_params,
                 subtitle: "Navegue entre captadores para comparar o desempenho." %>
    </section>
  <% end %>
</div>

<style>
.pagination {
  display: flex;
  justify-content: center;
  padding: 1em 0;
}

.pagination li {
  list-style: none;
}

.pagination li a {
  margin: 0 0.5em;
  padding: 0.5em 1em;
  border: 1px solid #e2e8f0; /* border-gray-300 */
  color: #4a5568; /* text-gray-700 */
}

.pagination li.active a,
.pagination li a:hover {
  background-color: #edf2f7; /* bg-gray-200 */
  color: #2d3748; /* text-gray-800 */
}

.pagination li.disabled a {
  color: #a0aec0; /* text-gray-400 */
  cursor: not-allowed;
}

/* If you are using SVG for the icons: */
.pagination li a svg {
  vertical-align: middle;
}
</style>

<link href="https://fonts.googleapis.com/icon?family=Material+Icons" rel="stylesheet">

<style>
@media (max-width: 768px) {

  .pagination {
    flex-direction: column;
  }

  .pagination li {
    margin: 10px;
  }
}
</style>

<script>
  function showLoadingAndSubmit(selectElement) {
    const selectedValue = selectElement.value;
    const loadingNotification = document.getElementById('loading-notification');
    const loadingPeriod = document.getElementById('loading-period');
    
    // Submit the form first
    selectElement.form.submit();
    
    // Only show loading for weekly and monthly views after submission
    if (selectedValue === 'weekly' || selectedValue === 'monthly') {
      // Update loading text based on selection
      loadingPeriod.textContent = selectedValue === 'weekly' ? 'semana' : 'mês';
      
      // Show loading notification with a small delay to ensure form submission
      setTimeout(function() {
        loadingNotification.style.display = 'flex';
        // Notification will persist until page reloads - no auto-hide
      }, 100);
    }
  }
  
  function hideLoadingNotification() {
    const loadingNotification = document.getElementById('loading-notification');
    loadingNotification.style.display = 'none';
  }
</script>

<style>
  .loading-spinner {
    width: 20px;
    height: 20px;
    border: 2px solid #f3f4f6;
    border-top: 2px solid #3b82f6;
    border-radius: 50%;
    animation: spin 1s linear infinite;
    flex-shrink: 0;
  }
  
  @keyframes spin {
    0% { transform: rotate(0deg); }
    100% { transform: rotate(360deg); }
  }
  
  #loading-notification {
    max-width: 300px;
    animation: slideIn 0.3s ease-out;
  }
  
  @keyframes slideIn {
    from {
      transform: translateX(100%);
      opacity: 0;
    }
    to {
      transform: translateX(0);
      opacity: 1;
    }
  }
</style>