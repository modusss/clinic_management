<% service_types = ClinicManagement::ServiceType.where(removed: false).order(:name).to_a %>
<% selected_service_type_id = service.service_type_id.presence || service_types.first&.id %>
<%= form_with(model: service, class: "space-y-4", data: { controller: "week-selection" }) do |form| %>
  <% if service.errors.any? %>
    <div class="bg-red-100 p-4 rounded">
      <h2 class="text-red-700"><%= pluralize(service.errors.count, "erro") %> impediram que este atendimento fosse salvo:</h2>
      <ul class="list-disc list-inside">
        <% service.errors.each do |error| %>
          <li class="text-red-600"><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div>
    <%= form.label :service_type_id, "Tipo de atendimento", class: "block font-medium mb-2" %>
    <%= form.collection_select :service_type_id, 
        service_types,
        :id, 
        :name, 
        { selected: selected_service_type_id },
        class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm",
        data: {
          week_selection_target: "serviceType",
          action: "change->week-selection#filterServiceType"
        } %>
  </div>

  <div class="mt-6">
    <h3 class="font-medium mb-2">Selecione os dias de atendimento:</h3>

    <% service_types.each do |service_type| %>
      <% slots_by_week = available_time_slots_for_next_30_days(service_type_id: service_type.id).group_by { |slot| slot[:date].beginning_of_week } %>
      <div data-week-selection-target="typeSchedule"
           data-service-type-id="<%= service_type.id %>"
           <%= "hidden" unless service_type.id.to_s == selected_service_type_id.to_s %>>
      <% if slots_by_week.blank? %>
        <div class="rounded-lg border border-amber-200 bg-amber-50 px-4 py-3 text-amber-800">
          Não há novas datas disponíveis para <strong><%= service_type.name %></strong> nos próximos 30 dias.
        </div>
      <% end %>
      <% slots_by_week.each_with_index do |(week_start, week_slots), index| %>
      <% week_key = "#{service_type.id}-#{index}" %>
      <div class="mb-6">
        <div class="flex justify-between items-center border-b pb-2">
          <h4 class="text-lg font-medium text-gray-700">
            Semana <%= l(week_start, format: '%d/%m') %> - <%= l(week_start.end_of_week, format: '%d/%m/%Y') %>
          </h4>
          
          <div class="flex items-center">
            <input type="checkbox"
                   id="week_<%= week_key %>"
                   class="h-4 w-4 text-blue-600 border-gray-300 rounded mr-2"
                   data-week-selection-target="weekToggle"
                   data-action="click->week-selection#toggleWeek"
                   data-week-index="<%= week_key %>">
            <label for="week_<%= week_key %>" class="text-sm text-gray-600">
              Selecionar todos
            </label>
          </div>
        </div>
        
        <div class="grid grid-cols-1 md:grid-cols-1 gap-2" 
             data-week-selection-target="weekSlots" 
             data-week-index="<%= week_key %>">
          <% week_slots.each do |slot| %>
            <div class="border rounded p-2 <%= Date.current == slot[:date] ? 'bg-blue-50' : '' %>">
              <div class="flex items-center">
                <%= check_box_tag "time_slots_dates[]",
                    { time_slot_id: slot[:time_slot].id, date: slot[:date] }.to_json,
                    false,
                    id: "time_slot_#{service_type.id}_#{slot[:time_slot].id}_#{slot[:date].to_s.gsub('-', '_')}",
                    class: "h-4 w-4 text-blue-600 border-gray-300 rounded slot-checkbox",
                    data: {
                      week_selection_target: "slot",
                      week_index: week_key,
                      action: "click->week-selection#checkWeekStatus"
                    } %>
                
                <label for="time_slot_<%= service_type.id %>_<%= slot[:time_slot].id %>_<%= slot[:date].to_s.gsub('-', '_') %>" class="ml-3" style="width: 100%">
                  <div class="flex justify-between items-center">
                    <span class="font-medium text-gray-700">
                      <%= slot[:formatted_date] %>
                    </span>
                    <span class="text-sm text-gray-500">
                      <%= slot[:formatted_time] %>
                    </span>
                  </div>
                </label>
              </div>
            </div>
          <% end %>
        </div>
      </div>
      <% end %>
      </div>
    <% end %>
  </div>

  <div class="flex justify-end mt-6">
    <%= form.submit "Criar atendimentos", class: "bg-blue-500 text-white px-4 py-2 rounded hover:bg-blue-600" %>
  </div>
<% end %>
